    .story-card p {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.58;
    }

    .program-heading {
      color: var(--accent-dark);
      font-size: 18px;
      font-weight: 560;
      margin: 2px 0 0;
    }

    .parent-conclusion {
      background: transparent;
      border: 0;
      border-radius: var(--radius-card);
      padding: 14px 0 0;
      color: var(--ink-soft);
    }

    .parent-conclusion h2 {
      color: var(--ink-soft);
      font-size: 14px;
      font-weight: 560;
      margin-bottom: 10px;
    }

    .table-wrap,
    .table-scroll {
      max-width: 100%;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      border: 1px solid var(--line);
      border-radius: var(--radius-panel);
      margin-top: 10px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--paper);
      font-size: 12.5px;
    }

    .table-scroll table {
      min-width: 640px;
    }

    .tournament-list .table-scroll table {
      min-width: 640px;
    }

    th, td {
      border-bottom: 1px solid var(--line);
      padding: 10px 14px;
      text-align: left;
      vertical-align: top;
      overflow-wrap: anywhere;
    }

    th {
      background: #F5F2FC;
      color: #4A4568;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .04em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    tbody tr:nth-child(even) td { background: #FEFDFF; }
    tbody tr:last-child td { border-bottom: 0; }

    .col-dance { min-width: 170px; }
    .col-program { min-width: 110px; }
    .col-avg { min-width: 118px; }
    .col-best { min-width: 104px; }
    .col-place { min-width: 118px; }
    .col-protocols { min-width: 108px; }
    .col-stability {
      min-width: 190px;
      padding-left: 22px;
    }

    th.col-stability,
    td.col-stability {
      text-align: left;
    }

    .col-stability .progress-track {
      max-width: 148px;
    }

    details {
      border: 0;
      border-top: 1px solid var(--line);
      border-radius: 0;
      background: transparent;
      padding: 18px 0;
      margin-top: 0;
    }

    details:first-child {
      border-top: 0;
    }

    summary {
      cursor: pointer;
      color: var(--ink);
      font-size: 16px;
      font-weight: 560;
      list-style: none;
    }

    summary::-webkit-details-marker {
      display: none;
    }

    .tournament-list {
      display: grid;
      gap: 0;
    }

    .tournament-summary-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 12px;
      align-items: center;
      min-width: 0;
    }

    .tournament-summary {
      display: grid;
      grid-template-columns: minmax(92px, .35fr) minmax(180px, 1.1fr) minmax(180px, 1fr);
      gap: 12px;
      align-items: start;
      color: var(--ink);
      min-width: 0;
    }

    .tournament-summary > div {
      min-width: 0;
    }

    .accordion-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 30px;
      height: 30px;
      border-radius: var(--radius-circle);
      background: var(--accent-light);
      color: var(--accent-dark);
      flex: 0 0 auto;
      line-height: 0;
      transform-origin: 50% 50%;
      transition: transform .18s ease, background .18s ease;
    }

    .accordion-icon .status-icon {
      width: 18px;
      height: 18px;
      flex-basis: 18px;
      margin: 0;
      background: transparent;
      color: inherit;
    }

    .accordion-icon svg {
      width: 18px;
      height: 18px;
      stroke-width: 2;
    }

    details[open] .accordion-icon {
      transform: rotate(180deg);
      background: var(--accent-soft);
    }

    .section-accordion summary {
      font-size: 21px;
      font-weight: 600;
      color: var(--ink);
    }

    .section-summary-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 12px;
      align-items: center;
    }

    .tournament-title-line {
      min-width: 0;
      overflow-wrap: anywhere;
    }

    .tournament-badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 6px;
    }

    .tournament-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--chip-gap);
      min-height: var(--chip-small-min-height);
      border-radius: var(--chip-radius);
      background: var(--accent-positive-bg);
      color: var(--accent-positive);
      font-size: var(--chip-small-font-size);
      font-weight: var(--chip-small-font-weight);
      line-height: var(--chip-small-line-height);
      letter-spacing: 0;
      padding: var(--chip-small-padding-y) var(--chip-small-padding-x);
      white-space: nowrap;
    }

    .tournament-badge.hardest {
      color: var(--accent-attention);
      background: var(--accent-attention-bg);
    }

    .summary-title {
      font-weight: 600;
      color: var(--ink);
      overflow-wrap: anywhere;
    }

    .summary-meta {
      color: var(--muted-soft);
      font-size: 12px;
      margin-top: 4px;
      overflow-wrap: anywhere;
    }

    .tournament-program-briefs {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 7px;
    }

    .tournament-program-brief {
      display: inline-flex;
      align-items: baseline;
      gap: 5px;
      min-width: 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.35;
      font-weight: 400;
    }

    .tournament-program-brief strong {
      color: var(--ink-soft);
      font-size: 13px;
      font-weight: 620;
    }

    .tournament-program-brief span {
      color: var(--muted-soft);
    }

    details.filterable-tournament,
    details.filterable-tournament summary {
      max-width: 100%;
      min-width: 0;
      box-sizing: border-box;
    }

    details.filterable-tournament > * {
      max-width: 100%;
      min-width: 0;
      box-sizing: border-box;
    }

    @media (max-width: 900px) {
      .profile-grid,
      .kpi-grid,
      .insight-grid,
      .two-column,
      .three-column,
      .story-grid,
      .tournament-summary {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 620px) {
      .report { width: min(100% - 24px, 1080px); padding-top: 18px; }
      .cover, .section { padding: 18px; border-radius: var(--radius-card); }
      h1 { font-size: 26px; }
      .cover-subtitle { font-size: 14px; }
      .profile-grid,
      .kpi-grid,
      .insight-grid,
      .two-column,
      .three-column,
      .story-grid,
      .tournament-summary,
      .judge-insight-grid {
        grid-template-columns: 1fr;
      }
      .filter-grid,
      .date-filter-grid { grid-template-columns: 1fr; }
      .header-filter-panel {
        grid-template-columns: 1fr;
        gap: 12px;
      }
      .header-date-filter {
        grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
        justify-self: stretch;
      }
      .header-date-filter input {
        min-width: 0;
      }
      .tournament-summary-row {
        grid-template-columns: minmax(0, 1fr) auto;
        width: 100%;
        max-width: 100%;
        min-width: 0;
      }
      .tournament-summary,
      .tournament-summary > div,
      .tournament-title-line,
      .tournament-program-briefs,
      .summary-title,
      .summary-meta {
        max-width: 100%;
        min-width: 0;
      }
      .tournament-badge {
        white-space: normal;
        text-align: left;
      }
      .table-scroll {
        width: 100%;
        margin-left: 0;
        margin-right: 0;
      }
      .table-wrap.mobile-card-table,
      .table-scroll.mobile-card-table {
        border: 0;
        overflow: visible;
        max-width: 100%;
        min-width: 0;
      }
      .mobile-card-table table,
      .mobile-card-table thead,
      .mobile-card-table tbody,
      .mobile-card-table tr,
      .mobile-card-table th,
      .mobile-card-table td {
        display: block;
        width: 100%;
        max-width: 100%;
        min-width: 0;
        box-sizing: border-box;
      }
      .mobile-card-table table {
        min-width: 0;
        background: transparent;
        table-layout: fixed;
      }
      .tournament-list .table-scroll.mobile-card-table table,
      .tournament-list .table-scroll.mobile-card-table .tournament-results-table {
        min-width: 0;
      }
      .mobile-card-table thead {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0 0 0 0);
      }
      .mobile-card-table tbody {
        display: grid;
        gap: 10px;
      }
      .mobile-card-table tr {
        background: var(--paper-soft);
        border: 1px solid rgba(233, 229, 244, .82);
        border-radius: var(--radius-card);
        padding: 10px 12px;
        overflow-wrap: anywhere;
      }
      .mobile-card-table td {
        border: 0;
        padding: 7px 0;
        display: grid;
        grid-template-columns: minmax(72px, .46fr) minmax(0, 1fr);
        gap: 12px;
        align-items: start;
        text-align: right;
        min-width: 0;
        overflow-wrap: anywhere;
        word-break: normal;
      }
      .mobile-card-table .number {
        white-space: normal;
      }
      .mobile-card-table td > * {
        min-width: 0;
        max-width: 100%;
      }
      .mobile-card-table .col-program,
      .mobile-card-table .col-dance,
      .mobile-card-table .col-place,
      .mobile-card-table strong {
        min-width: 0;
        white-space: normal;
        overflow-wrap: anywhere;
      }
      .mobile-card-table td + td {
        border-top: 1px solid rgba(233, 229, 244, .66);
      }
      .mobile-card-table td::before {
        content: attr(data-label);
        color: var(--muted);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .04em;
        text-align: left;
      }
      .mobile-card-table td:first-child {
        display: block;
        text-align: left;
        font-size: 15px;
        padding-bottom: 9px;
      }
      .mobile-card-table td:first-child::before {
        display: none;
      }
      .mobile-card-table td[colspan] {
        display: block;
        text-align: left;
      }
      .mobile-card-table td[colspan]::before {
        display: none;
      }
      .mobile-card-table .col-stability .progress-track {
        margin-left: auto;
      }
      .mobile-card-table .tournament-results-table tbody {
        gap: 8px;
      }
      .mobile-card-table .tournament-results-table tr {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto auto;
        gap: 4px 8px;
        align-items: center;
      }
      .mobile-card-table .tournament-results-table td {
        display: block;
        padding: 0;
        border-top: 0;
        text-align: left;
      }
      .mobile-card-table .tournament-results-table td::before {
        display: none;
      }
      .mobile-card-table .tournament-results-table .col-program {
        grid-column: 1;
        grid-row: 1;
        color: var(--muted);
        font-size: 12px;
        font-weight: 600;
      }
      .mobile-card-table .tournament-results-table .col-dance {
        grid-column: 2;
        grid-row: 1;
        font-size: 15px;
      }
      .mobile-card-table .tournament-results-table .col-place {
        grid-column: 3;
        grid-row: 1;
        text-align: right;
        font-weight: 600;
      }
      .mobile-card-table .tournament-results-table td[data-label="Результат"] {
        grid-column: 4;
        grid-row: 1;
        text-align: right;
        color: var(--ink-soft);
        white-space: normal;
      }
      .mobile-card-table .tournament-results-table td[data-label="Категория"],
      .mobile-card-table .tournament-results-table td[data-label="Тур"] {
        grid-column: 1 / -1;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.35;
      }
      .mobile-card-table .tournament-results-table td[data-label="Категория"] {
        grid-row: 2;
        margin-top: 3px;
      }
      .mobile-card-table .tournament-results-table td[data-label="Тур"] {
        grid-row: 3;
      }
      .rank-list li,
      .plain-list li {
        align-items: flex-start;
      }
      .dance-comparison {
        padding: 8px 0 2px;
      }
      .dance-comparison-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }
      .dance-metric-row {
        grid-template-columns: 1fr;
        gap: 4px;
      }
    }

    @media print {
      @page { size: A4; margin: 12mm; }
      body { background: #fff; font-size: 11px; }
      .report { width: 100%; padding: 0; }
      .cover, .section {
        box-shadow: none;
        break-inside: avoid;
        page-break-inside: avoid;
        border-radius: var(--radius-panel);
      }
      h1 { font-size: 24px; }
      h2, summary { font-size: 17px; }
      table { font-size: 10px; }
      th, td { padding: 5px 6px; }
      .table-wrap,
      .table-scroll { overflow: visible; }
    }
  </style>
</head>
<body>
<main class="report">
  <header class="cover">
    <div class="eyebrow">Отчёт по спортивным бальным танцам</div>
    <h1>{{ dancer.name }}</h1>
    <p class="cover-subtitle">
      {% if dancer.club or dancer.city %}{{ dancer.club or "нет данных" }}{% if dancer.city %}, {{ dancer.city }}{% endif %} · {% endif %}IDD {{ dancer.idd }}
    </p>
    {% if dancer.coaches_st or dancer.coaches_la or dancer.class_st or dancer.class_la or dancer.skr_class_st or dancer.skr_class_la %}
    <div class="dancer-profile-lines">
      {% if dancer.coaches_st %}<div><strong>Тренеры St:</strong> {{ dancer.coaches_st }}</div>{% endif %}
      {% if dancer.coaches_la %}<div><strong>Тренеры La:</strong> {{ dancer.coaches_la }}</div>{% endif %}
      {% if dancer.class_st or dancer.skr_class_st %}
        <div><strong>St:</strong>{% if dancer.class_st %} {{ dancer.class_st }}{% endif %}{% if dancer.skr_class_st %}{% if dancer.class_st %} ·{% endif %} СКРкл {{ dancer.skr_class_st }}{% if dancer.norm_status_st %} · {{ dancer.norm_status_st }}{% endif %}{% endif %}</div>
      {% endif %}
      {% if dancer.class_la or dancer.skr_class_la %}
        <div><strong>La:</strong>{% if dancer.class_la %} {{ dancer.class_la }}{% endif %}{% if dancer.skr_class_la %}{% if dancer.class_la %} ·{% endif %} СКРкл {{ dancer.skr_class_la }}{% if dancer.norm_status_la %} · {{ dancer.norm_status_la }}{% endif %}{% endif %}</div>
      {% endif %}
    </div>
    {% endif %}
    <div class="header-filter-panel" aria-label="Фильтры отчёта">
      <div class="header-city-filter">
        <div class="filter-chips" role="group" aria-label="Фильтр городов">
          <button class="city-chip report-filter-city-all" type="button" aria-pressed="true" aria-label="Показать все города">Все города</button>
          {% for city in filter_options.cities %}
            <button class="city-chip report-filter-city" type="button" data-city="{{ city }}" aria-pressed="true" aria-label="Фильтр города: {{ city }}">
              {{ city }}
            </button>
          {% endfor %}
        </div>
      </div>
      <div class="header-date-filter" role="group" aria-label="Фильтр периода">
        <input id="report-filter-date-from" type="date" value="{{ filter_options.date_from }}" aria-label="Дата начала периода">
        <span class="date-separator" aria-hidden="true">—</span>
        <input id="report-filter-date-to" type="date" value="{{ filter_options.date_to }}" aria-label="Дата окончания периода">
      </div>
    </div>
  </header>

  <nav class="page-nav" aria-label="Навигация по отчёту">
    <a href="#overview">Обзор</a>
    <a href="#dances">Танцы</a>
    <a href="#tournaments">Турниры</a>
    <a href="#judges">Судьи</a>
  </nav>

  <section class="mode-panel parent-panel">
    <section class="section">
      <h2>Общая оценка сезона</h2>
      <p class="section-kicker">Краткая сводка по турнирам и динамике выступлений.</p>
      <div class="kpi-grid">
        <div class="card"><div class="label">Турниры</div><div class="kpi-value" data-summary-tournaments>{{ summary.tournaments }}</div><div class="muted" data-summary-tournaments-text>{{ summary.tournaments|pluralize("турнир", "турнира", "турниров") }} в отчёте</div></div>
        <div class="card"><div class="label">Выступления</div><div class="kpi-value" data-summary-protocols>{{ summary.protocols }}</div><div class="muted" data-summary-protocols-text>{{ summary.protocols|pluralize("выступление", "выступления", "выступлений") }}</div></div>
        <div class="card"><div class="label">Период наблюдения</div><div class="kpi-value" style="font-size:20px" data-summary-period>{{ summary.date_from }} — {{ summary.date_to }}</div></div>
      </div>
      <div class="note-box">
        <div class="label">Общий вывод</div>
        <div class="big-status">{{ role_views.parent.season_status }}</div>
        <p>{{ role_views.parent.season_comment }}</p>
      </div>
    </section>

    <section class="section">
      <h2>Выводы по программам</h2>
      <p class="section-kicker">Стандарт и латина показаны отдельно, чтобы не смешивать разные программы.</p>
      {% for key, program in role_views.parent.programs.items() %}
      <div class="program-story">
        <h3 class="program-heading">{{ program.title|capitalize }}</h3>
        {% for group in program.category_groups %}
          <input class="category-input" type="radio" name="parent-cat-{{ key }}" id="parent-cat-{{ key }}-{{ group.key }}" {{ "checked" if loop.first else "" }}>
        {% endfor %}
        <div class="category-chip-groups">
          <div class="category-chip-group">
            <div class="category-group-title">Категории для родителя</div>
            <div class="category-tabs category-tabs-primary">
              {% for group in program.category_groups %}
                <label class="category-tab" for="parent-cat-{{ key }}-{{ group.key }}">{{ group.label }}</label>
              {% endfor %}
            </div>
          </div>
        </div>

        <div class="parent-category-panels">
          {% for group in program.category_groups %}
          <div class="parent-category-panel parent-panel-{{ key }}-{{ group.key }}">
            {% if group.included_categories|length > 1 %}
              <p class="section-kicker">В анализ включены старты: {{ group.included_categories|join(", ") }}</p>
            {% endif %}
            <div class="story-grid">
              <div class="story-card">
                <h4>Что получается лучше всего</h4>
                <p>{{ group.best_text }}</p>
              </div>
              <div class="story-card">
                <h4>Что требует внимания</h4>
                <p>{{ group.attention_text }}</p>
              </div>
            </div>
            <div class="story-card">
              <h4>Динамика</h4>
              <p>{{ group.trend_text }}</p>
              {% if group.attention_overlap_note %}
                <p class="muted">{{ group.attention_overlap_note }}</p>
              {% endif %}
              {% if group.limited %}
                <p class="muted">Для некоторых танцев пока недостаточно данных для устойчивых выводов.</p>
              {% endif %}
            </div>
            <div class="parent-conclusion">
              <h2>Общий вывод</h2>
              {% for line in group.overview %}
                <p>{{ line }}</p>
              {% endfor %}
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </section>

  </section>

  <section class="mode-panel trainer-panel" id="overview">
    {% for key, program in programs.items() %}
    <section class="section"{% if loop.first %} id="dances"{% endif %}>
      <h2>{{ program.title|capitalize }}</h2>

      {% for slice in program.category_slices %}
        <input class="category-input" type="radio" name="cat-{{ key }}" id="cat-{{ key }}-{{ slice.key }}" {{ "checked" if loop.first else "" }}>
      {% endfor %}
      <div class="category-chip-groups">
        {% if program.category_primary_slices %}
        <div class="category-chip-group">
          <div class="category-tabs category-tabs-primary">
            {% for slice in program.category_primary_slices %}
              <label class="category-tab" for="cat-{{ key }}-{{ slice.key }}">{{ slice.label }}</label>
            {% endfor %}
          </div>
        </div>
        {% endif %}
        {% if program.category_limited_slices %}
        <div class="category-chip-group category-chip-group-limited">
          <div class="category-group-title">Мало данных</div>
          <div class="category-tabs category-tabs-limited">
            {% for slice in program.category_limited_slices %}
              <label class="category-tab limited" for="cat-{{ key }}-{{ slice.key }}">
                {{ slice.label }}<span class="chip-badge">мало данных</span>
              </label>
            {% endfor %}
          </div>
        </div>
        {% endif %}
      </div>

      <div class="category-panels">
      {% for slice in program.category_slices %}
        <div class="category-panel panel-{{ key }}-{{ slice.key }}" data-category-panel data-program="{{ key }}" data-slice-key="{{ slice.key }}">
          {% if slice.analysis_note %}
            <p class="section-kicker">{{ slice.analysis_note }}</p>
          {% endif %}
          {% if slice.visibility_status == "limited" %}
            <div class="note-box limited-note">{{ icon("info", "neutral") }}Выборка ограничена: {{ slice.visibility.protocols_count|default(slice.protocol_count)|pluralize("протокол", "протокола", "протоколов") }}. Эти данные можно использовать как справку, но не как устойчивый вывод.</div>
          {% elif slice.protocol_count < 3 %}
            <div class="note-box limited-note">{{ icon("info", "neutral") }}Ограниченная выборка: {{ slice.protocol_count|pluralize("протокол", "протокола", "протоколов") }} в этом срезе.</div>
          {% endif %}

          {% if slice.visibility_status == "limited" %}
          <div class="three-column">
            <div class="insight-card neutral">
              <h3><span>Справка по участию</span>{{ icon("info") }}</h3>
              <p>{{ slice.visibility.marks_count|default(0)|pluralize("оценка", "оценки", "оценок") }} · {{ slice.visibility.tournaments_count|default(0)|pluralize("турнир", "турнира", "турниров") }}</p>
            </div>
            <div class="insight-card neutral">
              <h3>Танцы в срезе</h3>
              {% if slice.marks_derived_dance_metrics %}
                <p>{{ slice.marks_derived_dance_metrics|map(attribute="dance_code")|map("dance_label")|join(", ") }}</p>
              {% else %}
                <p class="muted">Данных по танцам мало.</p>
              {% endif %}
            </div>
            <div class="insight-card neutral">
              <h3>Как читать</h3>
              <p class="muted">Сравнения и динамика не выделяются, потому что выборка слишком мала для устойчивого вывода.</p>
            </div>
          </div>
          {% else %}
          <div class="dance-comparison" data-dynamic-comparison>
            <div class="dance-comparison-header">
              <h3>Сравнение танцев</h3>
              {{ icon("equal", "neutral") }}
            </div>
            {% if slice.display_mode == "all_equal" %}
              <div class="dance-comparison-zone neutral">
                <div class="dance-comparison-title"><span>Равный результат</span>{{ icon("equal", "neutral") }}</div>
                <p class="dance-comparison-message">Танцы показали одинаковый результат: {{ slice.tied_dances|map(attribute="dance")|map("dance_label")|join(", ") }} — место {{ slice.tied_metric_value|fmt }}.</p>
              </div>
            {% elif slice.display_mode == "single_dance" and slice.evaluated_dance %}
              <div class="dance-comparison-zone neutral">
                <div class="dance-comparison-title"><span>Оценённый танец</span>{{ icon("info", "neutral") }}</div>
                <div class="dance-name-list">{{ slice.evaluated_dance.dance|dance_label }}</div>
                <div class="dance-comparison-value">среднее место {{ slice.evaluated_dance.final_avg_place|fmt }}</div>
              </div>
            {% elif not slice.best and not slice.attention %}
              <div class="dance-comparison-zone neutral">
                <div class="dance-comparison-title"><span>Сравнение недоступно</span>{{ icon("info", "neutral") }}</div>
                <p class="dance-comparison-message">В этом срезе пока недостаточно данных для выделения сильной зоны и зоны внимания.</p>
              </div>
            {% else %}
              <div class="dance-comparison-grid">
                <div class="dance-comparison-zone positive">
                  <div class="dance-comparison-title"><span>Сильнее сейчас</span>{{ icon("star", "positive") }}</div>
                  {% if slice.best %}
                    <div class="dance-name-list">{{ slice.best|map(attribute="dance")|map("dance_label")|join(", ") }}</div>
                    <div class="dance-comparison-value">среднее место {{ slice.best[0].final_avg_place|fmt }}</div>
                  {% else %}
                    <p class="muted">Сильная зона в этом срезе не выделяется.</p>
                  {% endif %}
                </div>
                <div class="dance-comparison-zone attention">
                  <div class="dance-comparison-title"><span>Зона внимания</span>{{ icon("alert", "attention") }}</div>
                  {% if slice.attention %}
                    <div class="dance-name-list">{{ slice.attention|map(attribute="dance")|map("dance_label")|join(", ") }}</div>
                    <div class="dance-comparison-value">среднее место {{ slice.attention[0].final_avg_place|fmt }}</div>
                  {% else %}
                    <p class="muted">Зона внимания в этом срезе не выделяется.</p>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </div>

          <div class="dance-comparison dance-dynamics" data-dynamic-trends>
            <div class="dance-comparison-header">
              <h3>Динамика танцев</h3>
              {{ icon("up", "neutral") }}
            </div>
            <p class="trend-help">Динамика считается по изменению среднего места между ранней и последней доступной датой выбранного периода. Меньшее место означает лучший результат.</p>
            {% if not slice.improving and not slice.declining %}
              <div class="dance-comparison-zone neutral">
                <div class="dance-comparison-title"><span>Без заметных изменений</span>{{ icon("equal", "neutral") }}</div>
                <p class="dance-comparison-message">{{ "Динамика неустойчива из-за ограниченной выборки." if not slice.enough_data else "Заметных изменений по динамике пока нет." }}</p>
              </div>
            {% else %}
              <div class="dance-comparison-grid">
                <div class="dance-comparison-zone positive">
                  <div class="dance-comparison-title"><span>Улучшается</span>{{ icon("up", "positive") }}</div>
                  {% if slice.improving %}
                    <div class="dance-metric-list">
                    {% for item in slice.improving %}
                      <div class="dance-metric-row">
                        <span class="dance-name-line">{{ item.dance|dance_label }}</span>
                        <span class="dance-comparison-value">среднее место: {{ item.first_avg_place|fmt }} → {{ item.last_avg_place|fmt }}</span>
                      </div>
                    {% endfor %}
                    </div>
                  {% else %}
                    <p class="trend-empty">{{ "Динамика неустойчива из-за ограниченной выборки." if not slice.enough_data else "Явного улучшения по тренду сейчас не видно." }}</p>
                  {% endif %}
                </div>
                <div class="dance-comparison-zone attention">
                  <div class="dance-comparison-title"><span>Требует внимания</span>{{ icon("down", "attention") }}</div>
                  {% if slice.declining %}
                    <div class="dance-metric-list">
                    {% for item in slice.declining %}
                      <div class="dance-metric-row">
                        <span class="dance-name-line">{{ item.dance|dance_label }}</span>
                        <span class="dance-comparison-value">среднее место: {{ item.first_avg_place|fmt }} → {{ item.last_avg_place|fmt }}</span>
                      </div>
                    {% endfor %}
                    </div>
                  {% else %}
                    <p class="trend-empty">{{ "Динамика неустойчива из-за ограниченной выборки." if not slice.enough_data else "Тревожной динамики по тренду сейчас не видно." }}</p>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </div>
          {% endif %}

          <h3 class="dance-table-heading">Стабильность танцев</h3>
          <p class="helper-text">Стабильность показывает, насколько сильно меняется итоговое место танца от турнира к турниру. Чем меньше колебания, тем выше стабильность.</p>
          <div class="table-wrap table-scroll mobile-card-table">
            <table>
              <thead><tr><th class="col-dance">Танец</th><th class="number col-avg">Среднее место</th><th class="number col-best">Лучшее</th><th class="col-stability">Стабильность</th></tr></thead>
              <tbody data-dynamic-metrics>
              {% for item in slice.metrics %}
                <tr>
                  <td class="col-dance" data-label="Танец"><strong>{{ item.dance|dance_label }}</strong></td>
                  <td class="number col-avg" data-label="Среднее место">{{ item.final_avg_place|fmt }}</td>
                  <td class="number col-best" data-label="Лучшее">{{ item.best_place|fmt }}</td>
                  <td class="col-stability" data-label="Стабильность">
                    <div class="progress-label">{{ item.stability_label }}</div>
                    <div class="progress-track"><div class="progress-fill" style="{{ item.stability_style }}"></div></div>
                  </td>
                </tr>
              {% endfor %}
              {% if not slice.metrics %}
                <tr><td colspan="4" data-label="Статус">{{ "Нет устойчивых метрик по танцам в этом срезе." if slice.visibility_status == "limited" else "Ограниченная выборка." }}</td></tr>
              {% endif %}
              </tbody>
            </table>
          </div>

        </div>
      {% endfor %}
      </div>
      <p class="helper-text">Расчёт стабильности основан на разбросе итоговых мест по турнирам. Полная шкала означает очень устойчивый результат, короткая шкала — сильные колебания.</p>
    </section>
    {% endfor %}

    <section class="section" id="tournaments">
      <h2>Турниры</h2>
      <p class="section-kicker">Лучшие и наиболее сложные выступления отмечены прямо в списке.</p>
      <div class="tournament-list">
        <div class="filter-empty" data-tournament-empty hidden>В выбранном периоде нет турниров.</div>
        {% for item in trainer_tournament_summaries %}
        <details class="filterable-tournament" data-city="{{ item.city or '' }}" data-date="{{ item.event_date or '' }}" data-tournament-id="{{ item.tournament_id }}" data-tournament-title="{{ item.tournament_title }}">
          <summary>
            <div class="tournament-summary-row">
              <div class="tournament-summary">
                <div>
                  <div class="summary-title">{{ item.event_date }}</div>
                  {% if item.city %}<div class="summary-meta">{{ item.city }}</div>{% endif %}
                </div>
                <div>
                  <div class="tournament-title-line">
                    <div class="summary-title">{{ item.tournament_title }}</div>
                  </div>
                  {% if item.program_briefs %}
                  <div class="tournament-program-briefs">
                    {% for brief in item.program_briefs %}
                      {% set brief_parts = brief.text.split(":", 1) %}
                      <div class="tournament-program-brief">
                        {% if brief_parts|length > 1 %}
                          <strong>{{ brief_parts[0] }}</strong><span>{{ brief_parts[1]|trim }}</span>
                        {% else %}
                          <span>{{ brief.text }}</span>
                        {% endif %}
                      </div>
                    {% endfor %}
                  </div>
                  {% endif %}
                  <div class="tournament-badge-row" data-rank-badge>
                  {% if item.rank_direction == "best" or item.rank_direction == "hardest" %}
                    {% if item.rank_direction == "best" %}
                      <span class="tournament-badge best">Лучший результат</span>
                    {% elif item.rank_direction == "hardest" %}
                      <span class="tournament-badge hardest">Сложное выступление</span>
                    {% endif %}
                  {% endif %}
                  </div>
                </div>
                <div>
                  <div class="summary-meta">{{ (item.categories_display or item.categories)|join("; ") }}</div>
                  <div class="summary-meta">{{ item.programs|map("program_label")|join(", ") }}</div>
                </div>
              </div>
              <span class="accordion-icon" aria-hidden="true">{{ icon("chevron") }}</span>
            </div>
          </summary>
          <div class="table-wrap table-scroll mobile-card-table">
            <table class="tournament-results-table">
              <thead><tr><th class="col-program">Программа</th><th>Категория</th><th class="col-dance">Танец</th><th>Тур</th><th class="number col-place">Место</th><th>Результат</th></tr></thead>
              <tbody>
              {% for result in item.dance_results %}
                <tr>
                  <td class="col-program" data-label="Программа">{{ "St" if result.program == "standard" else ("La" if result.program == "latin" else (result.program|program_label)) }}</td>
                  <td data-label="Категория">{{ result.category_display or result.category or "нет данных" }}</td>
                  <td class="col-dance" data-label="Танец"><strong>{{ (result.dance_code or (result.dance|dance_code))|dance_label }}</strong></td>
                  <td data-label="Тур">{{ result.round_label or "нет данных" }}</td>
                  <td class="number col-place" data-label="Место">{{ result.result_place_label or ((result.final_place|fmt) ~ " место" if result.final_place is not none else "нет данных") }}</td>
                  <td data-label="Результат">{{ result.marks_label or "нет данных" }}</td>
                </tr>
              {% endfor %}
              </tbody>
            </table>
          </div>
        </details>
        {% endfor %}
      </div>
    </section>

    <section class="section" id="judges">
      <h2>Что видят судьи</h2>
      <p class="section-kicker">Экспериментальный тренерский взгляд: не список всех судей, а то, где панель сходится, расходится и кто сильнее влияет на восприятие результата.</p>
      {% set consistency_metrics = dances.metrics|default([])|selectattr("judge_std_deviation")|list|sort(attribute="judge_std_deviation") %}
      <div class="judge-insight-grid">
        {% if consistency_metrics %}
        <div class="judge-insight-card" data-judge-consistency-card>
          <h3>Согласованность оценок</h3>
          <div data-judge-consistency-content>
            {% set consistent_dance = consistency_metrics|first %}
            {% set disputed_dance = consistency_metrics|last %}
            <div class="judge-consensus-list">
              <div class="judge-consensus-item">
                <div class="judge-consensus-name">{{ consistent_dance.dance|dance_label }}</div>
                <div><span class="judge-consensus-badge positive">Согласованный танец</span></div>
                <div class="judge-insight-meta">Разброс оценок низкий: {{ consistent_dance.judge_std_deviation|fmt }}</div>
              </div>
              <div class="judge-consensus-item">
                <div class="judge-consensus-name">{{ disputed_dance.dance|dance_label }}</div>
                <div><span class="judge-consensus-badge attention">Спорный танец</span></div>
                <div class="judge-insight-meta">Разброс оценок высокий: {{ disputed_dance.judge_std_deviation|fmt }}</div>
              </div>
            </div>
          </div>
        </div>
        {% endif %}
        <div class="judge-insight-card" data-judge-impact-card>
          <h3>Судьи с наибольшим влиянием</h3>
          <p class="judge-insight-description">Эти судьи чаще остальных отклоняются от среднего результата танцора.</p>
          <div data-judge-impact-list>
          {% if judges.strictest or judges.softest %}
            {% for item in judges.strictest %}
              {% if loop.index <= 2 %}
              <div class="judge-insight-item">
                <div class="judge-list-name">{{ item.judge }}</div>
                <div class="judge-insight-meta">отклонение {{ item.avg_deviation|fmt }} · {{ item.n_marks|pluralize("оценка", "оценки", "оценок") }}</div>
              </div>
              {% endif %}
            {% endfor %}
            {% for item in judges.softest %}
              {% if loop.index <= 1 %}
              <div class="judge-insight-item">
                <div class="judge-list-name">{{ item.judge }}</div>
                <div class="judge-insight-meta">отклонение {{ item.avg_deviation|fmt }} · {{ item.n_marks|pluralize("оценка", "оценки", "оценок") }}</div>
              </div>
              {% endif %}
            {% endfor %}
          {% else %}
            <p class="muted">Недостаточно данных для выделения судей с наибольшим влиянием.</p>
          {% endif %}
          </div>
        </div>
        {% if judge_panel_reaction and judge_panel_reaction.panel_spread_trend %}
        <div class="judge-insight-card" data-judge-panel-card>
          <h3>Реакция судейской панели</h3>
          <div data-judge-panel-content>
          {% if judge_panel_reaction.panel_spread_trend == "more_consistent" %}
            <div class="judge-insight-headline">Оценки судей становятся согласованнее</div>
          {% elif judge_panel_reaction.panel_spread_trend == "less_consistent" %}
            <div class="judge-insight-headline">Оценки судей стали менее согласованными</div>
          {% else %}
            <div class="judge-insight-headline">Без заметных изменений</div>
          {% endif %}
          <div class="judge-insight-meta">
            Разброс судей: {{ judge_panel_reaction.panel_spread_first|fmt }} → {{ judge_panel_reaction.panel_spread_last|fmt }}
          </div>
          </div>
        </div>
        {% endif %}
      </div>
    </section>

    <section class="section">
      <details class="section-accordion">
        <summary>
          <span class="section-summary-row">
            <span>Дополнительная аналитика судей</span>
            <span class="accordion-icon" aria-hidden="true">{{ icon("chevron") }}</span>
          </span>
        </summary>
        <p class="section-kicker">В рейтинг включены только судьи, по которым доступно не менее 10 оценок.</p>
        <div class="judge-table-stack">
          <div class="judge-table-block">
            <h3>Более строгие судьи</h3>
            <div class="table-wrap table-scroll mobile-card-table">
              <table>
                <thead><tr><th>Судья</th><th>Интерпретация</th><th class="number">Отклонение</th><th class="number">Оценок</th><th class="number">Протоколов</th></tr></thead>
                <tbody data-judge-strict-body>
              {% if judges.strictest %}
              {% for item in judges.strictest %}
                <tr>
                  <td data-label="Судья"><strong>{{ item.judge }}</strong></td>
                  <td data-label="Интерпретация"><div class="interpretation">{{ item.judge_label }}</div></td>
                  <td class="number" data-label="Отклонение">{{ item.avg_deviation|fmt }}</td>
                  <td class="number" data-label="Оценок">{{ item.n_marks|pluralize("оценка", "оценки", "оценок") }}</td>
                  <td class="number" data-label="Протоколов">{{ item.protocols|pluralize("протокол", "протокола", "протоколов") }}</td>
                </tr>
              {% endfor %}
              {% else %}
                <tr><td colspan="5" data-label="Статус">Недостаточно данных для формирования рейтинга судей.</td></tr>
              {% endif %}
                </tbody>
              </table>
            </div>
          </div>
          <div class="judge-table-block">
            <h3>Более мягкие судьи</h3>
            <div class="table-wrap table-scroll mobile-card-table">
              <table>
                <thead><tr><th>Судья</th><th>Интерпретация</th><th class="number">Отклонение</th><th class="number">Оценок</th><th class="number">Протоколов</th></tr></thead>
                <tbody data-judge-soft-body>
              {% if judges.softest %}
              {% for item in judges.softest %}
                <tr>
                  <td data-label="Судья"><strong>{{ item.judge }}</strong></td>
                  <td data-label="Интерпретация"><div class="interpretation">{{ item.judge_label }}</div></td>
                  <td class="number" data-label="Отклонение">{{ item.avg_deviation|fmt }}</td>
                  <td class="number" data-label="Оценок">{{ item.n_marks|pluralize("оценка", "оценки", "оценок") }}</td>
                  <td class="number" data-label="Протоколов">{{ item.protocols|pluralize("протокол", "протокола", "протоколов") }}</td>
                </tr>
              {% endfor %}
              {% else %}
                <tr><td colspan="5" data-label="Статус">Недостаточно данных для формирования рейтинга судей.</td></tr>
              {% endif %}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </details>
    </section>

  </section>
</main>
  <script id="report-data" type="application/json">{{ report|tojson }}</script>
  <script>
  (function () {
    var reportData = JSON.parse(document.getElementById("report-data").textContent || "{}");
    var cityAllButton = document.querySelector(".report-filter-city-all");
    var cityButtons = Array.prototype.slice.call(document.querySelectorAll(".report-filter-city"));
    var dateFrom = document.getElementById("report-filter-date-from");
    var dateTo = document.getElementById("report-filter-date-to");
    var items = Array.prototype.slice.call(document.querySelectorAll(".filterable-tournament"));
    var danceRows = (((reportData || {}).tournaments || {}).dance_results || []);
    var numericMarks = (((reportData || {}).client_data || {}).numeric_marks || []);
    var tournamentItems = (((reportData || {}).tournaments || {}).items || []);
    var danceOrder = { W: 1, T: 2, V: 3, F: 4, Q: 5, S: 6, Ch: 7, C: 7, R: 8, P: 9, J: 10 };
    var danceLabels = {
      W: "Медленный вальс", T: "Танго", V: "Венский вальс", VW: "Венский вальс", F: "Медленный фокстрот", Q: "Квикстеп",
      S: "Самба", Ch: "Ча-ча-ча", C: "Ча-ча-ча", R: "Румба", P: "Пасодобль", J: "Джайв"
    };

    function isPressed(button) {
      return button && button.getAttribute("aria-pressed") === "true";
    }

    function setPressed(button, value) {
      if (button) button.setAttribute("aria-pressed", value ? "true" : "false");
    }

    function syncAllButton() {
      var allSelected = cityButtons.length === 0 || cityButtons.every(isPressed);
      setPressed(cityAllButton, allSelected);
    }

    function selectAllCities() {
      cityButtons.forEach(function (button) { setPressed(button, true); });
      setPressed(cityAllButton, true);
    }

    function selectedCities() {
      var selected = cityButtons
        .filter(isPressed)
        .map(function (button) { return button.getAttribute("data-city") || ""; })
        .filter(Boolean);
      if (!selected.length) {
        selectAllCities();
        return cityButtons.map(function (button) { return button.getAttribute("data-city") || ""; }).filter(Boolean);
      }
      return selected;
    }

    function inDateRange(value, from, to) {
      if (!value) return true;
      if (from && value < from) return false;
      if (to && value > to) return false;
      return true;
    }

    function escapeHtml(value) {
      return String(value == null ? "" : value).replace(/[&<>"']/g, function (char) {
        return {"&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;"}[char];
      });
    }

    function fmt(value, digits) {
      digits = digits == null ? 3 : digits;
      if (value == null || Number.isNaN(Number(value))) return "—";
      var num = Number(value);
      var rounded = Math.round(num);
      if (Math.abs(num - rounded) < Math.pow(10, -digits)) return String(rounded);
      return num.toFixed(digits).replace(/0+$/, "").replace(/\.$/, "");
    }

    function plural(value, one, few, many) {
      var n = Math.abs(Number(value) || 0);
      var mod10 = n % 10;
      var mod100 = n % 100;
      var word = (mod10 === 1 && mod100 !== 11) ? one : ([2, 3, 4].indexOf(mod10) !== -1 && [12, 13, 14].indexOf(mod100) === -1 ? few : many);
      return String(value) + " " + word;
    }

    function danceLabel(value) {
      return danceLabels[value] || value || "—";
    }

    function sortDances(items) {
      return items.slice().sort(function (a, b) {
        var ac = a.dance_code || a.dance;
        var bc = b.dance_code || b.dance;
        return (danceOrder[ac] || 999) - (danceOrder[bc] || 999) || String(ac).localeCompare(String(bc));
      });
    }

    function selectedFilter() {
      return {
        cities: selectedCities(),
        from: dateFrom ? dateFrom.value : "",
        to: dateTo ? dateTo.value : ""
      };
    }

    function rowCity(row) {
      return row.city || row.tournament_city || "";
    }

    function rowDate(row) {
      return row.event_date || row.date || "";
    }

    function rowMatches(row, filter) {
      var city = rowCity(row);
      var date = rowDate(row);
      var cityOk = !city || filter.cities.indexOf(city) !== -1;
      return cityOk && inDateRange(date, filter.from, filter.to);
    }

    function selectedTournamentItems(filter) {
      return tournamentItems
        .filter(function (row) { return rowMatches(row, filter); })
        .sort(function (a, b) {
          var dateCompare = String(rowDate(b)).localeCompare(String(rowDate(a)));
          if (dateCompare) return dateCompare;
          return String(b.tournament_id || "").localeCompare(String(a.tournament_id || ""));
        });
    }

    function sortTournamentCards() {
      var list = document.querySelector(".tournament-list");
      if (!list) return;
      items.slice().sort(function (a, b) {
        var dateCompare = String(b.getAttribute("data-date") || "").localeCompare(String(a.getAttribute("data-date") || ""));
        if (dateCompare) return dateCompare;
        return String(b.getAttribute("data-tournament-id") || "").localeCompare(String(a.getAttribute("data-tournament-id") || ""));
      }).forEach(function (item) {
        list.appendChild(item);
      });
    }

    function selectedNumericRows(filter) {
      return numericMarks.filter(function (row) { return rowMatches(row, filter) && row.numeric_mark != null; });
    }

    function createFilteredDataset(filter) {
      var filteredTournaments = selectedTournamentItems(filter);
      var allowedTournamentKeys = {};
      filteredTournaments.forEach(function (row) {
        allowedTournamentKeys[tournamentKey(row)] = true;
      });
      var filteredDanceRows = danceRows.filter(function (row) {
        return row.final_place != null && allowedTournamentKeys[tournamentKey(row)];
      });
      return {
        filter: filter,
        filteredTournaments: filteredTournaments,
        filteredDanceRows: filteredDanceRows,
        filteredNumericMarks: selectedNumericRows(filter)
      };
    }

    function uniqueCount(rows, key) {
      var values = {};
      rows.forEach(function (row) {
        if (row[key] != null && row[key] !== "") values[row[key]] = true;
      });
      return Object.keys(values).length;
    }

    function mean(values) {
      if (!values.length) return null;
      return values.reduce(function (sum, value) { return sum + Number(value); }, 0) / values.length;
    }

    function std(values) {
      if (values.length < 2) return 0;
      var avg = mean(values);
      var variance = values.reduce(function (sum, value) { return sum + Math.pow(Number(value) - avg, 2); }, 0) / (values.length - 1);
      return Math.sqrt(variance);
    }

    function categorySource(program, sliceKey) {
      var slice = (((reportData.category_slices || {})[program] || {})[sliceKey] || {});
      return slice.source_categories || [];
    }

    function rowsForPanel(program, sliceKey, dataset) {
      var categories = categorySource(program, sliceKey);
      return dataset.filteredDanceRows.filter(function (row) {
        if (row.program !== program) return false;
        if (sliceKey !== "all" && categories.length && categories.indexOf(row.category) === -1) return false;
        return true;
      });
    }

    function metricsFromRows(rows) {
      var byDance = {};
      rows.forEach(function (row) {
        var code = row.dance_code || row.dance;
        if (!byDance[code]) byDance[code] = { dance: row.dance, dance_code: code, values: [], protocols: {}, dates: {} };
        byDance[code].values.push(Number(row.final_place));
        if (row.protocol_id != null) byDance[code].protocols[row.protocol_id] = true;
        if (row.event_date) byDance[code].dates[row.event_date] = true;
      });
      var metrics = Object.keys(byDance).map(function (code) {
        var item = byDance[code];
        var values = item.values;
        return {
          dance: item.dance,
          dance_code: item.dance_code,
          final_avg_place: mean(values),
          best_place: Math.min.apply(null, values),
          final_std_deviation: std(values),
          n_protocols: Object.keys(item.protocols).length,
          n_dates: Object.keys(item.dates).length
        };
      });
      metrics = sortDances(metrics);
      var stabilities = metrics.map(function (item) { return item.final_std_deviation; });
      var minStd = stabilities.length ? Math.min.apply(null, stabilities) : 0;
      var maxStd = stabilities.length ? Math.max.apply(null, stabilities) : 0;
      metrics.forEach(function (item) {
        var percent = 78;
        if (maxStd !== minStd) {
          percent = Math.round(95 - ((item.final_std_deviation - minStd) / (maxStd - minStd)) * 70);
          percent = Math.max(18, Math.min(95, percent));
        }
        item.stability_percent = percent;
        item.stability_label = percent >= 86 ? "Очень высокая" : (percent >= 68 ? "Высокая" : (percent >= 48 ? "Средняя" : (percent >= 30 ? "Низкая" : "Очень низкая")));
      });
      return metrics;
    }

    function comparisonFromMetrics(metrics) {
      var scored = metrics.filter(function (item) { return item.final_avg_place != null; }).sort(function (a, b) { return a.final_avg_place - b.final_avg_place; });
      if (!scored.length) return { mode: "none" };
      if (scored.length === 1) return { mode: "single", item: scored[0] };
      var best = scored[0].final_avg_place;
      var worst = scored[scored.length - 1].final_avg_place;
      if (Math.abs(best - worst) < 0.001) return { mode: "equal", items: scored, value: best };
      return {
        mode: "best_worst",
        best: scored.filter(function (item) { return Math.abs(item.final_avg_place - best) < 0.001; }),
        worst: scored.filter(function (item) { return Math.abs(item.final_avg_place - worst) < 0.001; })
      };
    }

    function trendsFromRows(rows) {
      var grouped = {};
      rows.forEach(function (row) {
        var code = row.dance_code || row.dance;
        var date = row.event_date || row.date;
        if (!date) return;
        grouped[code] = grouped[code] || {};
        grouped[code][date] = grouped[code][date] || [];
        grouped[code][date].push(Number(row.final_place));
      });
      var improving = [];
      var declining = [];
      Object.keys(grouped).forEach(function (code) {
        var dates = Object.keys(grouped[code]).sort();
        if (dates.length < 2) return;
        var first = mean(grouped[code][dates[0]]);
        var last = mean(grouped[code][dates[dates.length - 1]]);
        var item = { dance_code: code, first_avg_place: first, last_avg_place: last };
        if (Math.abs(last - first) < 0.001) return;
        if (last < first) improving.push(item);
        else declining.push(item);
      });
      return { improving: sortDances(improving), declining: sortDances(declining) };
    }

    function renderComparison(element, metrics) {
      if (!element) return;
      var comparison = comparisonFromMetrics(metrics);
      var html = '<div class="dance-comparison-header"><h3>Сравнение танцев</h3></div>';
      if (comparison.mode === "none") {
        html += '<div class="dance-comparison-zone neutral"><div class="dance-comparison-title"><span>Сравнение недоступно</span></div><p class="dance-comparison-message">В выбранном периоде нет данных для сравнения танцев.</p></div>';
      } else if (comparison.mode === "single") {
        html += '<div class="dance-comparison-zone neutral"><div class="dance-comparison-title"><span>Оценённый танец</span></div><div class="dance-name-list">' + escapeHtml(danceLabel(comparison.item.dance_code)) + '</div><div class="dance-comparison-value">среднее место ' + fmt(comparison.item.final_avg_place) + '</div></div>';
      } else if (comparison.mode === "equal") {
        html += '<div class="dance-comparison-zone neutral"><div class="dance-comparison-title"><span>Равный результат</span></div><p class="dance-comparison-message">Танцы показали одинаковый результат: ' + escapeHtml(comparison.items.map(function (item) { return danceLabel(item.dance_code); }).join(", ")) + ' — место ' + fmt(comparison.value) + '.</p></div>';
      } else {
        html += '<div class="dance-comparison-grid"><div class="dance-comparison-zone positive"><div class="dance-comparison-title"><span>Сильнее сейчас</span></div><div class="dance-name-list">' + escapeHtml(comparison.best.map(function (item) { return danceLabel(item.dance_code); }).join(", ")) + '</div><div class="dance-comparison-value">среднее место ' + fmt(comparison.best[0].final_avg_place) + '</div></div>';
        html += '<div class="dance-comparison-zone attention"><div class="dance-comparison-title"><span>Зона внимания</span></div><div class="dance-name-list">' + escapeHtml(comparison.worst.map(function (item) { return danceLabel(item.dance_code); }).join(", ")) + '</div><div class="dance-comparison-value">среднее место ' + fmt(comparison.worst[0].final_avg_place) + '</div></div></div>';
      }
      element.innerHTML = html;
    }

    function renderTrends(element, rows) {
      if (!element) return;
      var trends = trendsFromRows(rows);
      var html = '<div class="dance-comparison-header"><h3>Динамика танцев</h3></div><p class="trend-help">Динамика пересчитывается по выбранному периоду: сравнивается среднее место на первой и последней доступной дате. Меньшее место означает лучший результат.</p>';
      if (!trends.improving.length && !trends.declining.length) {
        html += '<div class="dance-comparison-zone neutral"><div class="dance-comparison-title"><span>Без заметных изменений</span></div><p class="dance-comparison-message">Заметных изменений по динамике в выбранном периоде пока нет.</p></div>';
      } else {
        html += '<div class="dance-comparison-grid"><div class="dance-comparison-zone positive"><div class="dance-comparison-title"><span>Улучшается</span></div>';
        html += trends.improving.length ? trends.improving.map(function (item) { return '<div class="dance-metric-row"><span class="dance-name-line">' + escapeHtml(danceLabel(item.dance_code)) + '</span><span class="dance-comparison-value">среднее место: ' + fmt(item.first_avg_place) + ' → ' + fmt(item.last_avg_place) + '</span></div>'; }).join("") : '<p class="trend-empty">Явного улучшения по тренду сейчас не видно.</p>';
        html += '</div><div class="dance-comparison-zone attention"><div class="dance-comparison-title"><span>Требует внимания</span></div>';
        html += trends.declining.length ? trends.declining.map(function (item) { return '<div class="dance-metric-row"><span class="dance-name-line">' + escapeHtml(danceLabel(item.dance_code)) + '</span><span class="dance-comparison-value">среднее место: ' + fmt(item.first_avg_place) + ' → ' + fmt(item.last_avg_place) + '</span></div>'; }).join("") : '<p class="trend-empty">Тревожной динамики по тренду сейчас не видно.</p>';
        html += '</div></div>';
      }
      element.innerHTML = html;
    }

    function renderMetricTable(tbody, metrics) {
      if (!tbody) return;
      if (!metrics.length) {
        tbody.innerHTML = '<tr><td colspan="4" data-label="Статус">В выбранном периоде нет данных по танцам.</td></tr>';
        return;
      }
      tbody.innerHTML = metrics.map(function (item) {
        return '<tr><td class="col-dance" data-label="Танец"><strong>' + escapeHtml(danceLabel(item.dance_code)) + '</strong></td>' +
          '<td class="number col-avg" data-label="Среднее место">' + fmt(item.final_avg_place) + '</td>' +
          '<td class="number col-best" data-label="Лучшее">' + fmt(item.best_place) + '</td>' +
          '<td class="col-stability" data-label="Стабильность"><div class="progress-label">' + escapeHtml(item.stability_label) + '</div><div class="progress-track"><div class="progress-fill" style="width: ' + item.stability_percent + '%"></div></div></td></tr>';
      }).join("");
    }

    function updateProgramPanels(dataset) {
      Array.prototype.slice.call(document.querySelectorAll("[data-category-panel]")).forEach(function (panel) {
        var program = panel.getAttribute("data-program");
        var sliceKey = panel.getAttribute("data-slice-key") || "all";
        var rows = rowsForPanel(program, sliceKey, dataset);
        var metrics = metricsFromRows(rows);
        renderComparison(panel.querySelector("[data-dynamic-comparison]"), metrics);
        renderTrends(panel.querySelector("[data-dynamic-trends]"), rows);
        renderMetricTable(panel.querySelector("[data-dynamic-metrics]"), metrics);
      });
    }

    function tournamentKey(row) {
      return [row.event_date || row.date || "", row.tournament_id || "", row.tournament_title || ""].join("||");
    }

    function updateTournamentRanks(dataset) {
      var rows = dataset.filteredDanceRows;
      var grouped = {};
      rows.forEach(function (row) {
        var key = tournamentKey(row);
        grouped[key] = grouped[key] || [];
        grouped[key].push(Number(row.final_place));
      });
      var ranked = Object.keys(grouped).map(function (key) {
        return { key: key, avg: mean(grouped[key]) };
      }).sort(function (a, b) { return a.avg - b.avg; });
      var topLimit = ranked.length <= 5 ? 2 : 3;
      var best = {};
      var hardest = {};
      ranked.slice(0, topLimit).forEach(function (item) { best[item.key] = true; });
      ranked.slice().reverse().filter(function (item) { return !best[item.key]; }).slice(0, topLimit).forEach(function (item) { hardest[item.key] = true; });
      items.forEach(function (item) {
        var key = [item.getAttribute("data-date") || "", item.getAttribute("data-tournament-id") || "", item.getAttribute("data-tournament-title") || ""].join("||");
        var badge = item.querySelector("[data-rank-badge]");
        if (!badge) return;
        if (best[key]) badge.innerHTML = '<span class="tournament-badge best">Лучший результат</span>';
        else if (hardest[key]) badge.innerHTML = '<span class="tournament-badge hardest">Сложное выступление</span>';
        else badge.innerHTML = "";
      });
    }

    function judgeStats(dataset) {
      var rows = dataset.filteredNumericMarks;
      var panels = {};
      rows.forEach(function (row) {
        var key = [row.protocol_db_id, row.round, row.dance].join("||");
        panels[key] = panels[key] || [];
        panels[key].push(Number(row.numeric_mark));
      });
      var panelAvg = {};
      Object.keys(panels).forEach(function (key) { panelAvg[key] = mean(panels[key]); });
      var judges = {};
      rows.forEach(function (row) {
        var key = [row.protocol_db_id, row.round, row.dance].join("||");
        var judge = row.judge || "—";
        judges[judge] = judges[judge] || { judge: judge, deviations: [], protocols: {} };
        judges[judge].deviations.push(Number(row.numeric_mark) - panelAvg[key]);
        if (row.protocol_id != null) judges[judge].protocols[row.protocol_id] = true;
      });
      return Object.keys(judges).map(function (name) {
        var item = judges[name];
        return {
          judge: name,
          avg_deviation: mean(item.deviations),
          n_marks: item.deviations.length,
          protocols: Object.keys(item.protocols).length
        };
      }).filter(function (item) { return item.n_marks >= 10; });
    }

    function judgeConsistencyByDance(dataset) {
      var rows = dataset.filteredNumericMarks;
      var byDance = {};
      rows.forEach(function (row) {
        var code = row.dance || "";
        if (!code) return;
        byDance[code] = byDance[code] || [];
        byDance[code].push(Number(row.numeric_mark));
      });
      return Object.keys(byDance).map(function (code) {
        return {
          dance_code: code,
          spread: std(byDance[code]),
          marks: byDance[code].length
        };
      }).filter(function (item) {
        return item.marks >= 2;
      }).sort(function (a, b) {
        return a.spread - b.spread;
      });
    }

    function panelReaction(dataset) {
      var rows = dataset.filteredNumericMarks;
      var panels = {};
      rows.forEach(function (row) {
        var key = [row.protocol_db_id, row.round, row.dance].join("||");
        panels[key] = panels[key] || { date: row.event_date || row.date || "", values: [] };
        panels[key].values.push(Number(row.numeric_mark));
      });
      var byDate = {};
      Object.keys(panels).forEach(function (key) {
        var panel = panels[key];
        if (!panel.date || panel.values.length < 2) return;
        byDate[panel.date] = byDate[panel.date] || [];
        byDate[panel.date].push(std(panel.values));
      });
      var dates = Object.keys(byDate).sort();
      if (dates.length < 2) return null;
      var tournamentSpreads = dates.map(function (date) {
        return { date: date, spread: mean(byDate[date]) };
      });
      var windowSize = Math.max(1, Math.ceil(tournamentSpreads.length * 0.4));
      var first = mean(tournamentSpreads.slice(0, windowSize).map(function (item) { return item.spread; }));
      var last = mean(tournamentSpreads.slice(-windowSize).map(function (item) { return item.spread; }));
      var delta = last - first;
      var trend = Math.abs(delta) < 0.15 ? "stable" : (delta < 0 ? "more_consistent" : "less_consistent");
      return { first: first, last: last, trend: trend };
    }

    function updateJudgeConsistency(dataset) {
      var card = document.querySelector("[data-judge-consistency-card]");
      var content = document.querySelector("[data-judge-consistency-content]");
      if (!card || !content) return;
      var rows = judgeConsistencyByDance(dataset);
      if (!rows.length) {
        card.hidden = true;
        return;
      }
      card.hidden = false;
      var consistent = rows[0];
      var disputed = rows[rows.length - 1];
      content.innerHTML = '<div class="judge-consensus-list">' +
        '<div class="judge-consensus-item"><div class="judge-consensus-name">' + escapeHtml(danceLabel(consistent.dance_code)) + '</div><div><span class="judge-consensus-badge positive">Согласованный танец</span></div><div class="judge-insight-meta">Разброс оценок низкий: ' + fmt(consistent.spread) + '</div></div>' +
        '<div class="judge-consensus-item"><div class="judge-consensus-name">' + escapeHtml(danceLabel(disputed.dance_code)) + '</div><div><span class="judge-consensus-badge attention">Спорный танец</span></div><div class="judge-insight-meta">Разброс оценок высокий: ' + fmt(disputed.spread) + '</div></div>' +
        '</div>';
    }

    function updatePanelReaction(dataset) {
      var card = document.querySelector("[data-judge-panel-card]");
      var content = document.querySelector("[data-judge-panel-content]");
      if (!card || !content) return;
      var reaction = panelReaction(dataset);
      if (!reaction) {
        card.hidden = true;
        return;
      }
      card.hidden = false;
      var headline = "Без заметных изменений";
      if (reaction.trend === "more_consistent") headline = "Оценки судей становятся согласованнее";
      if (reaction.trend === "less_consistent") headline = "Оценки судей стали менее согласованными";
      content.innerHTML = '<div class="judge-insight-headline">' + escapeHtml(headline) + '</div>' +
        '<div class="judge-insight-meta">Разброс судей: ' + fmt(reaction.first) + ' → ' + fmt(reaction.last) + '</div>';
    }

    function judgeLabel(value) {
      if (value > 0.6) return "Строже среднего";
      if (value < -0.6) return "Мягче среднего";
      return "Близко к среднему";
    }

    function renderJudgeBody(tbody, rows) {
      if (!tbody) return;
      if (!rows.length) {
        tbody.innerHTML = '<tr><td colspan="5" data-label="Статус">Недостаточно данных для формирования рейтинга судей.</td></tr>';
        return;
      }
      tbody.innerHTML = rows.map(function (item) {
        return '<tr><td data-label="Судья"><strong>' + escapeHtml(item.judge) + '</strong></td>' +
          '<td data-label="Интерпретация"><div class="interpretation">' + escapeHtml(judgeLabel(item.avg_deviation)) + '</div></td>' +
          '<td class="number" data-label="Отклонение">' + fmt(item.avg_deviation) + '</td>' +
          '<td class="number" data-label="Оценок">' + plural(item.n_marks, "оценка", "оценки", "оценок") + '</td>' +
          '<td class="number" data-label="Протоколов">' + plural(item.protocols, "протокол", "протокола", "протоколов") + '</td></tr>';
      }).join("");
    }

    function updateJudges(dataset) {
      var stats = judgeStats(dataset);
      var strict = stats.slice().sort(function (a, b) { return b.avg_deviation - a.avg_deviation; }).slice(0, 10);
      var soft = stats.slice().sort(function (a, b) { return a.avg_deviation - b.avg_deviation; }).slice(0, 10);
      renderJudgeBody(document.querySelector("[data-judge-strict-body]"), strict);
      renderJudgeBody(document.querySelector("[data-judge-soft-body]"), soft);
      var impact = stats.slice().sort(function (a, b) { return Math.abs(b.avg_deviation) - Math.abs(a.avg_deviation); }).slice(0, 3);
      var list = document.querySelector("[data-judge-impact-list]");
      if (list) {
        list.innerHTML = impact.length ? impact.map(function (item) {
          return '<div class="judge-insight-item"><div class="judge-list-name">' + escapeHtml(item.judge) + '</div><div class="judge-insight-meta">отклонение ' + fmt(item.avg_deviation) + ' · ' + plural(item.n_marks, "оценка", "оценки", "оценок") + '</div></div>';
        }).join("") : '<p class="muted">Недостаточно данных для выделения судей с наибольшим влиянием.</p>';
      }
      updateJudgeConsistency(dataset);
      updatePanelReaction(dataset);
    }

    function updateSummary(dataset) {
      var rows = dataset.filteredDanceRows;
      var tournaments = dataset.filteredTournaments;
      var dates = tournaments.map(function (item) { return item.event_date || item.date; }).filter(Boolean).sort();
      var tournamentCount = uniqueCount(tournaments, "tournament_id");
      var protocolCount = uniqueCount(rows, "protocol_id");
      var el;
      if ((el = document.querySelector("[data-summary-tournaments]"))) el.textContent = tournamentCount;
      if ((el = document.querySelector("[data-summary-tournaments-text]"))) el.textContent = plural(tournamentCount, "турнир", "турнира", "турниров") + " в отчёте";
      if ((el = document.querySelector("[data-summary-protocols]"))) el.textContent = protocolCount;
      if ((el = document.querySelector("[data-summary-protocols-text]"))) el.textContent = plural(protocolCount, "выступление", "выступления", "выступлений");
      if ((el = document.querySelector("[data-summary-period]"))) el.textContent = dates.length ? dates[0] + " — " + dates[dates.length - 1] : "нет данных";
    }

    function applyFilters() {
      var filter = selectedFilter();
      var filteredDataset = createFilteredDataset(filter);
      sortTournamentCards();
      items.forEach(function (item) {
        var city = item.getAttribute("data-city") || "";
        var date = item.getAttribute("data-date") || "";
        var cityOk = !city || filter.cities.indexOf(city) !== -1;
        var dateOk = inDateRange(date, filter.from, filter.to);
        item.hidden = !(cityOk && dateOk);
      });
      var tournamentEmpty = document.querySelector("[data-tournament-empty]");
      if (tournamentEmpty) tournamentEmpty.hidden = filteredDataset.filteredTournaments.length !== 0;
      updateSummary(filteredDataset);
      updateProgramPanels(filteredDataset);
      updateTournamentRanks(filteredDataset);
      updateJudges(filteredDataset);
    }

    function initPageNav() {
      var links = Array.prototype.slice.call(document.querySelectorAll(".page-nav a"));
      var sections = links
        .map(function (link) {
          var target = document.querySelector(link.getAttribute("href") || "");
          return target ? { link: link, target: target } : null;
        })
        .filter(Boolean);
      if (!sections.length) return;

      function setActive(id) {
        sections.forEach(function (item) {
          item.link.classList.toggle("is-active", item.target.id === id);
        });
      }

      function updateActiveFromScroll() {
        var activeId = sections[0].target.id;
        var marker = 96;
        sections.forEach(function (item) {
          if (item.target.getBoundingClientRect().top <= marker) {
            activeId = item.target.id;
          }
        });
        setActive(activeId);
      }

      if ("IntersectionObserver" in window) {
        var observer = new IntersectionObserver(function (entries) {
          var visible = entries
            .filter(function (entry) { return entry.isIntersecting; })
            .sort(function (a, b) { return b.intersectionRatio - a.intersectionRatio; })[0];
          if (visible && visible.target && visible.target.id) setActive(visible.target.id);
        }, { rootMargin: "-84px 0px -60% 0px", threshold: [0.08, 0.2, 0.45] });
        sections.forEach(function (item) { observer.observe(item.target); });
      }

      window.addEventListener("scroll", updateActiveFromScroll, { passive: true });

      links.forEach(function (link) {
        link.addEventListener("click", function () {
          var targetId = (link.getAttribute("href") || "").replace("#", "");
          if (targetId) setActive(targetId);
        });
      });

      updateActiveFromScroll();
    }

    if (cityAllButton) {
      cityAllButton.addEventListener("click", function () {
        selectAllCities();
        applyFilters();
      });
    }
    cityButtons.forEach(function (button) {
      button.addEventListener("click", function () {
        setPressed(button, !isPressed(button));
        if (!cityButtons.some(isPressed)) {
          selectAllCities();
        } else {
          syncAllButton();
        }
        applyFilters();
      });
    });
    if (dateFrom) dateFrom.addEventListener("change", applyFilters);
    if (dateTo) dateTo.addEventListener("change", applyFilters);
    Array.prototype.slice.call(document.querySelectorAll(".category-input")).forEach(function (input) {
      input.addEventListener("change", applyFilters);
    });
    selectAllCities();
    initPageNav();
    applyFilters();
  }());
</script>
</body>
</html>
