{% macro icon(name, extra_class="") -%}
<span class="status-icon {{ extra_class }}" aria-hidden="true">
  {% if name == "star" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="m12 3 2.7 5.47 6.03.88-4.36 4.25 1.03 6-5.4-2.84-5.4 2.84 1.03-6-4.36-4.25 6.03-.88L12 3Z"/></svg>
  {% elif name == "alert" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.3 4.2 2.8 17.4A2 2 0 0 0 4.5 20h15a2 2 0 0 0 1.7-2.6L13.7 4.2a2 2 0 0 0-3.4 0Z"/></svg>
  {% elif name == "info" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="M12 11v5"/><path d="M12 8h.01"/><circle cx="12" cy="12" r="9"/></svg>
  {% elif name == "equal" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="M6 9h12"/><path d="M6 15h12"/></svg>
  {% elif name == "up" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="M12 19V5"/><path d="m6 11 6-6 6 6"/></svg>
  {% elif name == "down" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14"/><path d="m18 13-6 6-6-6"/></svg>
  {% elif name == "chevron" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="m6 9 6 6 6-6"/></svg>
  {% endif %}
</span>
{%- endmacro %}
<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Отчёт танцора · {{ dancer.name }} · {{ dancer.idd }}</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #F8F7FC;
      --paper: #FFFFFF;
      --paper-soft: #FDFBFF;
      --ink: #20212A;
      --ink-soft: #3D3F4C;
      --muted: #727488;
      --muted-soft: #8D8FA0;
      --line: #E9E5F4;
      --accent: #7B6ED6;
      --accent-dark: #5E51B8;
      --accent-soft: #F0EDFB;
      --accent-light: #FAF8FF;
      --note-soft: #F6F4FC;
      --success-soft: #EAF6F1;
      --accent-positive: #4F8F78;
      --accent-positive-bg: #F1F8F5;
      --accent-warning: #9A7745;
      --accent-warning-bg: #FFF8EA;
      --accent-attention: #B27670;
      --accent-attention-bg: #FCF2F0;
      --accent-neutral: #7A7692;
      --accent-neutral-bg: #F5F3FA;
      --shadow: 0 10px 26px rgba(49, 42, 96, .055);
      --radius-control: 999px;
      --radius-card: 14px;
      --radius-panel: 12px;
      --radius-section: 18px;
      --radius-circle: 999px;
      --chip-radius: var(--radius-control);
      --control-large-font-size: 13px;
      --control-large-font-weight: 560;
      --control-large-min-height: 34px;
      --control-large-padding-y: 7px;
      --control-large-padding-x: 12px;
      --chip-small-font-size: 12px;
      --chip-small-font-weight: 560;
      --chip-small-line-height: 1.2;
      --chip-small-min-height: 28px;
      --chip-small-padding-y: 5px;
      --chip-small-padding-x: 10px;
      --chip-gap: 6px;
      --chip-badge-font-size: 10px;
      --chip-badge-font-weight: 560;
      --chip-badge-min-height: 18px;
      --chip-badge-padding-y: 2px;
      --chip-badge-padding-x: 6px;
    }

    * { box-sizing: border-box; }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--ink);
      font: 14px/1.62 Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
    }

    .report {
      width: min(1080px, calc(100% - 40px));
      margin: 0 auto;
      padding: 34px 0 64px;
    }

    .cover {
      background: linear-gradient(135deg, var(--paper) 0%, var(--accent-light) 100%);
      border: 1px solid var(--line);
      border-radius: var(--radius-section);
      box-shadow: var(--shadow);
      padding: 34px 36px 28px;
      margin-bottom: 18px;
    }

    .eyebrow {
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 620;
      letter-spacing: .08em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    h1, h2, h3, h4 { margin: 0; line-height: 1.2; letter-spacing: 0; }
    h1 { font-size: 34px; max-width: 760px; font-weight: 660; }
    h2 { font-size: 21px; margin-bottom: 12px; font-weight: 600; }
    h3 { font-size: 16px; margin: 0 0 10px; font-weight: 560; color: var(--ink-soft); }
    h4 { font-size: 13px; margin: 0 0 8px; font-weight: 560; color: var(--ink-soft); }
    p { margin: 0 0 10px; }

    .cover-subtitle {
      color: var(--ink-soft);
      font-size: 16px;
      margin-top: 8px;
    }

    .dancer-profile-lines {
      display: grid;
      gap: 4px;
      margin-top: 12px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .dancer-profile-lines strong {
      color: var(--ink-soft);
      font-weight: 560;
    }

    .header-filter-panel {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, auto);
      gap: 14px;
      align-items: center;
      margin-top: 22px;
      padding-top: 18px;
      border-top: 1px solid rgba(233, 229, 244, .78);
    }

    .page-nav {
      display: flex;
      flex-wrap: nowrap;
      gap: 8px;
      align-items: center;
      position: sticky;
      top: 10px;
      z-index: 20;
      width: max-content;
      max-width: 100%;
      margin: -4px 0 18px;
      padding: 6px;
      overflow-x: auto;
      border: 1px solid rgba(233, 229, 244, .86);
      border-radius: var(--radius-control);
      background: rgba(255, 255, 255, .86);
      box-shadow: 0 8px 22px rgba(49, 42, 96, .08);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      scrollbar-width: none;
    }

    .page-nav::-webkit-scrollbar {
      display: none;
    }

    .page-nav a {
      display: inline-flex;
      align-items: center;
      min-height: 30px;
      padding: 6px 11px;
      border-radius: var(--radius-control);
      background: rgba(255, 255, 255, .7);
      color: var(--muted);
      border: 1px solid rgba(233, 229, 244, .74);
      text-decoration: none;
      font-size: 12px;
      font-weight: 560;
      line-height: 1.2;
      white-space: nowrap;
    }

    .page-nav a:hover,
    .page-nav a.is-active {
      color: var(--accent-dark);
      border-color: rgba(123, 110, 214, .28);
      background: var(--paper);
    }

    .header-city-filter {
      min-width: 0;
    }

    .header-date-filter {
      display: grid;
      grid-template-columns: minmax(136px, 1fr) auto minmax(136px, 1fr);
      gap: 8px;
      align-items: center;
      justify-self: end;
    }

    .date-separator {
      color: var(--muted);
      font-size: 13px;
    }

    .profile-grid,
    .kpi-grid,
    .insight-grid,
    .two-column,
    .three-column {
      display: grid;
      gap: 12px;
    }

    .profile-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); margin-top: 22px; }
    .kpi-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .insight-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .two-column { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .three-column { grid-template-columns: repeat(3, minmax(0, 1fr)); }

    .profile-item,
    .card,
    .insight-card {
      background: rgba(255, 255, 255, .62);
      border-radius: var(--radius-card);
      padding: 14px;
      break-inside: avoid;
    }

    .profile-item,
    .card {
      border: 1px solid rgba(109, 91, 208, .11);
    }

    .insight-card {
      border: 0;
    }

    .insight-card.positive {
      background: var(--accent-positive-bg);
    }

    .insight-card.attention {
      background: var(--accent-attention-bg);
    }

    .insight-card.neutral {
      background: var(--accent-neutral-bg);
    }

    .insight-card h3 {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .insight-card h3 .status-icon {
      width: 32px;
      height: 32px;
      flex-basis: 32px;
      margin-left: auto;
    }

    .status-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: var(--radius-circle);
      background: var(--accent-neutral-bg);
      color: var(--accent-neutral);
      flex: 0 0 24px;
      margin-right: 2px;
      line-height: 0;
    }

    .status-icon svg {
      width: 15px;
      height: 15px;
      stroke: currentColor;
      stroke-width: 1.9;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .insight-card h3 .status-icon svg {
      width: 18px;
      height: 18px;
    }

    .dance-comparison {
      background: transparent;
      border: 0;
      border-radius: 0;
      padding: 8px 0 2px;
      margin: 18px 0 18px;
      break-inside: avoid;
    }

    .dance-comparison-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .dance-comparison-header h3 {
      color: var(--ink);
      font-size: 15px;
      font-weight: 600;
      margin: 0;
    }

    .dance-comparison-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .dance-comparison-zone {
      border-radius: var(--radius-panel);
      padding: 14px 15px;
      background: rgba(255, 255, 255, .72);
    }

    .dance-comparison-zone.positive {
      background: color-mix(in srgb, var(--accent-positive-bg) 68%, #fff);
    }

    .dance-comparison-zone.attention {
      background: color-mix(in srgb, var(--accent-attention-bg) 68%, #fff);
    }

    .dance-comparison-zone.neutral {
      background: color-mix(in srgb, var(--accent-neutral-bg) 72%, #fff);
    }

    .dance-comparison-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 560;
      margin-bottom: 8px;
    }

    .dance-name-list {
      color: var(--ink);
      font-size: 14px;
      font-weight: 580;
      line-height: 1.45;
      margin-bottom: 5px;
    }

    .dance-name-line {
      color: var(--ink);
      font-size: 13px;
      font-weight: 560;
      line-height: 1.45;
    }

    .dance-comparison-value {
      color: var(--muted);
      font-size: 12.5px;
      line-height: 1.45;
    }

    .dance-metric-list {
      display: grid;
      gap: 8px;
    }

    .dance-metric-row {
      display: grid;
      grid-template-columns: minmax(150px, 180px) minmax(120px, 1fr);
      column-gap: 16px;
      row-gap: 4px;
      align-items: center;
    }

    .trend-empty {
      color: var(--muted);
      font-size: 12.5px;
      line-height: 1.45;
      margin: 0;
    }

    .dance-comparison-message {
      color: var(--ink-soft);
      font-size: 14px;
      line-height: 1.55;
      margin: 0;
    }

    .status-icon.positive,
    .positive .status-icon {
      background: var(--accent-positive-bg);
      color: var(--accent-positive);
    }

    .status-icon.attention,
    .attention .status-icon {
      background: var(--accent-attention-bg);
      color: var(--accent-attention);
    }

    .status-icon.neutral,
    .neutral .status-icon,
    .limited-note .status-icon {
      background: var(--accent-neutral-bg);
      color: var(--accent-neutral);
    }

    .label {
      color: var(--muted);
      font-size: 11px;
      font-weight: 560;
      letter-spacing: .06em;
      text-transform: uppercase;
    }

    .value {
      color: var(--ink);
      font-weight: 600;
      margin-top: 4px;
      overflow-wrap: anywhere;
    }

    .category-input { position: absolute; opacity: 0; pointer-events: none; }

    .mode-panel { display: block; }
    .parent-panel { display: none; }

    .report-filters {
      background: var(--paper);
      border: 1px solid rgba(233, 229, 244, .78);
      border-radius: var(--radius-section);
      box-shadow: 0 6px 18px rgba(49, 42, 96, .03);
      margin: 0 0 24px;
      padding: 18px;
    }

    .filter-grid {
      display: grid;
      grid-template-columns: minmax(220px, 1.4fr) minmax(220px, 1fr);
      gap: 18px;
      align-items: start;
    }

    .filter-title {
      color: var(--ink-soft);
      font-size: 13px;
      font-weight: 560;
      margin-bottom: 8px;
    }

    .filter-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .filter-chip,
    .city-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--chip-gap);
      min-height: var(--control-large-min-height);
      border: 1px solid var(--line);
      border-radius: var(--chip-radius);
      background: var(--accent-light);
      color: var(--ink-soft);
      cursor: pointer;
      font-size: var(--control-large-font-size);
      font-weight: var(--control-large-font-weight);
      line-height: var(--chip-small-line-height);
      letter-spacing: 0;
      padding: var(--control-large-padding-y) var(--control-large-padding-x);
    }

    .city-chip {
      appearance: none;
      font-family: inherit;
      transition: background .16s ease, border-color .16s ease, color .16s ease;
    }

    .city-chip[aria-pressed="true"] {
      background: var(--accent-soft);
      border-color: rgba(94, 81, 184, .38);
      color: var(--accent-dark);
    }

    .filter-chip input {
      accent-color: var(--accent);
      margin: 0;
    }

    .date-filter-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .date-filter-grid input,
    .header-date-filter input {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: var(--radius-control);
      color: var(--ink-soft);
      font: inherit;
      font-size: var(--control-large-font-size);
      font-weight: var(--control-large-font-weight);
      min-height: var(--control-large-min-height);
      padding: var(--control-large-padding-y) var(--control-large-padding-x);
    }

    .filter-note {
      margin: 12px 0 0;
      color: var(--muted);
      font-size: 12px;
    }

    .filter-empty {
      display: none;
      color: var(--muted);
      margin-top: 12px;
    }

    .section {
      background: var(--paper);
      border: 1px solid rgba(233, 229, 244, .78);
      border-radius: var(--radius-section);
      box-shadow: 0 6px 18px rgba(49, 42, 96, .035);
      margin: 24px 0;
      padding: 24px;
      break-inside: avoid;
      scroll-margin-top: 76px;
    }

    .mode-panel[id] {
      scroll-margin-top: 76px;
    }

    .section-kicker {
      color: var(--muted-soft);
      font-size: 13px;
      max-width: 720px;
      margin-bottom: 14px;
    }

    .helper-text {
      color: var(--muted);
      font-size: 12px;
      font-weight: 400;
      line-height: 1.5;
      max-width: 760px;
      margin: 8px 0 12px;
    }

    .kpi-value,
    .big-status {
      color: var(--accent-dark);
      font-size: 26px;
      font-weight: 600;
      line-height: 1.05;
      margin-top: 8px;
    }

    .big-status { font-size: 23px; }

    .card {
      background: #FBFAFF;
      min-height: 110px;
    }

    .insight-card {
      background: var(--accent-light);
      min-height: 120px;
    }

    .rank-list,
    .plain-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 8px;
    }

    .rank-list li,
    .plain-list li {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      border-radius: var(--radius-panel);
      background: transparent;
      padding: 7px 0;
    }

    .rank-list li + li,
    .plain-list li + li {
      border-top: 1px solid rgba(233, 229, 244, .68);
    }

    .trend-help {
      color: var(--muted);
      font-size: 12.5px;
      line-height: 1.55;
      margin: 16px 0 12px;
      max-width: 780px;
    }

    .rank {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 28px;
      height: 28px;
      border-radius: var(--radius-circle);
      background: var(--accent);
      color: #fff;
      font-weight: 650;
      margin-right: 8px;
    }

    .muted { color: var(--muted); }
    .tiny { color: var(--muted); font-size: 11px; margin-top: 3px; }
    .number { text-align: right; white-space: nowrap; }

    .progress-label {
      display: block;
      color: var(--ink-soft);
      font-size: 12px;
      font-weight: 560;
      margin-bottom: 6px;
    }

    .stability-meter {
      display: block;
      flex: 0 0 132px;
      width: 132px;
      max-width: 46%;
    }

    .progress-track {
      display: block;
      width: 100%;
      min-width: 92px;
      height: 7px;
      border-radius: var(--radius-control);
      background: #ECE8F6;
      overflow: hidden;
    }

    .progress-fill {
      display: block;
      height: 100%;
      width: var(--stability-width, 0%);
      border-radius: inherit;
      background: linear-gradient(90deg, var(--accent-dark), var(--accent));
    }

    .category-chip-groups {
      display: grid;
      gap: 13px;
      margin: 16px 0 22px;
    }

    .category-chip-group {
      display: grid;
      gap: 7px;
    }

    .category-group-title {
      color: var(--muted);
      font-size: 11px;
      font-weight: 560;
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    .category-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 0;
    }

    .category-tab {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--chip-gap);
      min-height: var(--chip-small-min-height);
      cursor: pointer;
      border: 1px solid var(--line);
      border-radius: var(--chip-radius);
      background: var(--paper);
      color: var(--ink-soft);
      padding: var(--chip-small-padding-y) var(--chip-small-padding-x);
      font-size: var(--chip-small-font-size);
      font-weight: var(--chip-small-font-weight);
      line-height: var(--chip-small-line-height);
      letter-spacing: 0;
    }

    .category-tab.limited {
      color: var(--accent-neutral);
      background: var(--accent-neutral-bg);
      border-color: #DCD6EA;
      border-style: dashed;
      font-weight: var(--chip-small-font-weight);
    }

    .chip-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: var(--chip-badge-min-height);
      border-radius: var(--chip-radius);
      background: #E4DFF0;
      color: var(--accent-neutral);
      font-size: var(--chip-badge-font-size);
      font-weight: var(--chip-badge-font-weight);
      line-height: var(--chip-small-line-height);
      letter-spacing: 0;
      padding: var(--chip-badge-padding-y) var(--chip-badge-padding-x);
      vertical-align: middle;
    }

    .category-panel { display: none; padding-top: 2px; }
    .parent-category-panel { display: none; padding-top: 2px; }

    .category-panel > .note-box:first-child,
    .category-panel > .section-kicker:first-child {
      margin-top: 0;
    }

    .note-box + .three-column,
    .section-kicker + .note-box,
    .category-panel .three-column + .three-column {
      margin-top: 14px;
    }

    .dance-table-heading {
      margin-top: 22px;
    }

    #parent-cat-standard-all:checked ~ .category-chip-groups label[for="parent-cat-standard-all"],
    #parent-cat-standard-n_e:checked ~ .category-chip-groups label[for="parent-cat-standard-n_e"],
    #parent-cat-standard-e_d:checked ~ .category-chip-groups label[for="parent-cat-standard-e_d"],
    #parent-cat-standard-eadc:checked ~ .category-chip-groups label[for="parent-cat-standard-eadc"],
    #parent-cat-latin-all:checked ~ .category-chip-groups label[for="parent-cat-latin-all"],
    #parent-cat-latin-n_e:checked ~ .category-chip-groups label[for="parent-cat-latin-n_e"],
    #parent-cat-latin-e_d:checked ~ .category-chip-groups label[for="parent-cat-latin-e_d"],
    #parent-cat-latin-eadc:checked ~ .category-chip-groups label[for="parent-cat-latin-eadc"] {
      background: var(--accent-soft);
      border-color: rgba(94, 81, 184, .38);
      color: var(--accent-dark);
    }

    #parent-cat-standard-all:checked ~ .parent-category-panels .parent-panel-standard-all,
    #parent-cat-standard-n_e:checked ~ .parent-category-panels .parent-panel-standard-n_e,
    #parent-cat-standard-e_d:checked ~ .parent-category-panels .parent-panel-standard-e_d,
    #parent-cat-standard-eadc:checked ~ .parent-category-panels .parent-panel-standard-eadc,
    #parent-cat-latin-all:checked ~ .parent-category-panels .parent-panel-latin-all,
    #parent-cat-latin-n_e:checked ~ .parent-category-panels .parent-panel-latin-n_e,
    #parent-cat-latin-e_d:checked ~ .parent-category-panels .parent-panel-latin-e_d,
    #parent-cat-latin-eadc:checked ~ .parent-category-panels .parent-panel-latin-eadc {
      display: block;
    }

