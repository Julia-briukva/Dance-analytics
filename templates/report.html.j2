<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Отчёт танцора · {{ dancer.name }} · {{ dancer.idd }}</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #F8F7FC;
      --paper: #FFFFFF;
      --paper-soft: #FDFBFF;
      --ink: #20212A;
      --ink-soft: #3D3F4C;
      --muted: #727488;
      --line: #E9E5F4;
      --accent: #7B6ED6;
      --accent-dark: #5E51B8;
      --accent-soft: #F0EDFB;
      --accent-light: #FAF8FF;
      --note-soft: #F6F4FC;
      --success-soft: #EAF6F1;
      --shadow: 0 10px 26px rgba(49, 42, 96, .055);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--ink);
      font: 14px/1.62 Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
    }

    .report {
      width: min(1080px, calc(100% - 40px));
      margin: 0 auto;
      padding: 34px 0 64px;
    }

    .cover {
      background: linear-gradient(135deg, var(--paper) 0%, var(--accent-light) 100%);
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 34px 36px 28px;
      margin-bottom: 18px;
    }

    .eyebrow {
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 620;
      letter-spacing: .08em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    h1, h2, h3, h4 { margin: 0; line-height: 1.2; letter-spacing: 0; }
    h1 { font-size: 34px; max-width: 760px; font-weight: 680; }
    h2 { font-size: 22px; margin-bottom: 12px; font-weight: 620; }
    h3 { font-size: 17px; margin: 0 0 10px; font-weight: 560; color: var(--ink-soft); }
    h4 { font-size: 13px; margin: 0 0 8px; font-weight: 560; color: var(--ink-soft); }
    p { margin: 0 0 10px; }

    .cover-subtitle {
      color: var(--ink-soft);
      font-size: 16px;
      margin-top: 8px;
    }

    .profile-grid,
    .kpi-grid,
    .insight-grid,
    .two-column,
    .three-column {
      display: grid;
      gap: 12px;
    }

    .profile-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); margin-top: 22px; }
    .kpi-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .insight-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .two-column { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .three-column { grid-template-columns: repeat(3, minmax(0, 1fr)); }

    .profile-item,
    .card,
    .insight-card {
      background: rgba(255, 255, 255, .62);
      border-radius: 14px;
      padding: 14px;
      break-inside: avoid;
    }

    .profile-item,
    .card {
      border: 1px solid rgba(109, 91, 208, .11);
    }

    .insight-card {
      border: 0;
    }

    .label {
      color: var(--muted);
      font-size: 11px;
      font-weight: 560;
      letter-spacing: .06em;
      text-transform: uppercase;
    }

    .value {
      color: var(--ink);
      font-weight: 600;
      margin-top: 4px;
      overflow-wrap: anywhere;
    }

    .tabs {
      position: sticky;
      top: 0;
      z-index: 5;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      background: rgba(248, 247, 252, .94);
      backdrop-filter: blur(8px);
      padding: 10px 0 18px;
      margin-bottom: 12px;
    }

    .tab-input { position: absolute; opacity: 0; pointer-events: none; }
    .category-input { position: absolute; opacity: 0; pointer-events: none; }

    .tab-label {
      display: flex;
      flex-direction: column;
      gap: 3px;
      cursor: pointer;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--paper);
      color: var(--ink-soft);
      padding: 15px 18px;
      box-shadow: 0 6px 18px rgba(49, 42, 96, .04);
      transition: all .18s ease;
    }

    .tab-title {
      font-size: 16px;
      font-weight: 600;
    }

    .tab-help {
      color: var(--muted);
      font-size: 12px;
    }

    #tab-parent:checked ~ .tabs label[for="tab-parent"],
    #tab-trainer:checked ~ .tabs label[for="tab-trainer"] {
      background: var(--accent-soft);
      border-color: rgba(94, 81, 184, .42);
      color: var(--accent-dark);
      box-shadow: 0 6px 16px rgba(77, 61, 181, .07);
    }

    #tab-parent:checked ~ .tabs label[for="tab-parent"] .tab-help,
    #tab-trainer:checked ~ .tabs label[for="tab-trainer"] .tab-help {
      color: var(--muted);
    }

    .mode-panel { display: none; }
    #tab-parent:checked ~ .parent-panel { display: block; }
    #tab-trainer:checked ~ .trainer-panel { display: block; }

    .section {
      background: var(--paper);
      border: 1px solid rgba(233, 229, 244, .78);
      border-radius: 16px;
      box-shadow: 0 6px 18px rgba(49, 42, 96, .035);
      margin: 24px 0;
      padding: 24px;
      break-inside: avoid;
    }

    .section-kicker {
      color: var(--muted);
      font-size: 13px;
      max-width: 720px;
      margin-bottom: 14px;
    }

    .kpi-value,
    .big-status {
      color: var(--accent-dark);
      font-size: 26px;
      font-weight: 600;
      line-height: 1.05;
      margin-top: 8px;
    }

    .big-status { font-size: 23px; }

    .card {
      background: #FBFAFF;
      min-height: 110px;
    }

    .insight-card {
      background: var(--accent-light);
      min-height: 120px;
    }

    .rank-list,
    .plain-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 8px;
    }

    .rank-list li,
    .plain-list li {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      border-radius: 8px;
      background: transparent;
      padding: 7px 0;
    }

    .rank-list li + li,
    .plain-list li + li {
      border-top: 1px solid rgba(233, 229, 244, .68);
    }

    .rank {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 28px;
      height: 28px;
      border-radius: 999px;
      background: var(--accent);
      color: #fff;
      font-weight: 650;
      margin-right: 8px;
    }

    .muted { color: var(--muted); }
    .tiny { color: var(--muted); font-size: 11px; margin-top: 3px; }
    .number { text-align: right; white-space: nowrap; }

    .progress-label {
      display: block;
      color: var(--ink-soft);
      font-size: 12px;
      font-weight: 560;
      margin-bottom: 6px;
    }

    .stability-meter {
      display: block;
      flex: 0 0 132px;
      width: 132px;
      max-width: 46%;
    }

    .progress-track {
      display: block;
      width: 100%;
      min-width: 92px;
      height: 7px;
      border-radius: 999px;
      background: #ECE8F6;
      overflow: hidden;
    }

    .progress-fill {
      display: block;
      height: 100%;
      width: var(--stability-width, 0%);
      border-radius: inherit;
      background: linear-gradient(90deg, var(--accent-dark), var(--accent));
    }

    .category-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 14px 0 16px;
    }

    .category-tab {
      cursor: pointer;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--paper);
      color: var(--ink-soft);
      padding: 8px 12px;
      font-size: 12px;
      font-weight: 560;
    }

    .category-panel { display: none; }

    #cat-standard-all:checked ~ .category-tabs label[for="cat-standard-all"],
    #cat-standard-n:checked ~ .category-tabs label[for="cat-standard-n"],
    #cat-standard-n_e:checked ~ .category-tabs label[for="cat-standard-n_e"],
    #cat-standard-e:checked ~ .category-tabs label[for="cat-standard-e"],
    #cat-standard-e_d:checked ~ .category-tabs label[for="cat-standard-e_d"],
    #cat-standard-d:checked ~ .category-tabs label[for="cat-standard-d"],
    #cat-standard-d_c:checked ~ .category-tabs label[for="cat-standard-d_c"],
    #cat-standard-c:checked ~ .category-tabs label[for="cat-standard-c"],
    #cat-standard-c_b:checked ~ .category-tabs label[for="cat-standard-c_b"],
    #cat-standard-b:checked ~ .category-tabs label[for="cat-standard-b"],
    #cat-standard-a:checked ~ .category-tabs label[for="cat-standard-a"],
    #cat-standard-s:checked ~ .category-tabs label[for="cat-standard-s"],
    #cat-standard-m:checked ~ .category-tabs label[for="cat-standard-m"],
    #cat-standard-eadc:checked ~ .category-tabs label[for="cat-standard-eadc"],
    #cat-standard-open:checked ~ .category-tabs label[for="cat-standard-open"],
    #cat-latin-all:checked ~ .category-tabs label[for="cat-latin-all"],
    #cat-latin-n:checked ~ .category-tabs label[for="cat-latin-n"],
    #cat-latin-n_e:checked ~ .category-tabs label[for="cat-latin-n_e"],
    #cat-latin-e:checked ~ .category-tabs label[for="cat-latin-e"],
    #cat-latin-e_d:checked ~ .category-tabs label[for="cat-latin-e_d"],
    #cat-latin-d:checked ~ .category-tabs label[for="cat-latin-d"],
    #cat-latin-d_c:checked ~ .category-tabs label[for="cat-latin-d_c"],
    #cat-latin-c:checked ~ .category-tabs label[for="cat-latin-c"],
    #cat-latin-c_b:checked ~ .category-tabs label[for="cat-latin-c_b"],
    #cat-latin-b:checked ~ .category-tabs label[for="cat-latin-b"],
    #cat-latin-a:checked ~ .category-tabs label[for="cat-latin-a"],
    #cat-latin-s:checked ~ .category-tabs label[for="cat-latin-s"],
    #cat-latin-m:checked ~ .category-tabs label[for="cat-latin-m"],
    #cat-latin-eadc:checked ~ .category-tabs label[for="cat-latin-eadc"],
    #cat-latin-open:checked ~ .category-tabs label[for="cat-latin-open"] {
      background: var(--accent-soft);
      border-color: rgba(94, 81, 184, .38);
      color: var(--accent-dark);
    }

    #cat-standard-all:checked ~ .category-panels .panel-standard-all,
    #cat-standard-n:checked ~ .category-panels .panel-standard-n,
    #cat-standard-n_e:checked ~ .category-panels .panel-standard-n_e,
    #cat-standard-e:checked ~ .category-panels .panel-standard-e,
    #cat-standard-e_d:checked ~ .category-panels .panel-standard-e_d,
    #cat-standard-d:checked ~ .category-panels .panel-standard-d,
    #cat-standard-d_c:checked ~ .category-panels .panel-standard-d_c,
    #cat-standard-c:checked ~ .category-panels .panel-standard-c,
    #cat-standard-c_b:checked ~ .category-panels .panel-standard-c_b,
    #cat-standard-b:checked ~ .category-panels .panel-standard-b,
    #cat-standard-a:checked ~ .category-panels .panel-standard-a,
    #cat-standard-s:checked ~ .category-panels .panel-standard-s,
    #cat-standard-m:checked ~ .category-panels .panel-standard-m,
    #cat-standard-eadc:checked ~ .category-panels .panel-standard-eadc,
    #cat-standard-open:checked ~ .category-panels .panel-standard-open,
    #cat-latin-all:checked ~ .category-panels .panel-latin-all,
    #cat-latin-n:checked ~ .category-panels .panel-latin-n,
    #cat-latin-n_e:checked ~ .category-panels .panel-latin-n_e,
    #cat-latin-e:checked ~ .category-panels .panel-latin-e,
    #cat-latin-e_d:checked ~ .category-panels .panel-latin-e_d,
    #cat-latin-d:checked ~ .category-panels .panel-latin-d,
    #cat-latin-d_c:checked ~ .category-panels .panel-latin-d_c,
    #cat-latin-c:checked ~ .category-panels .panel-latin-c,
    #cat-latin-c_b:checked ~ .category-panels .panel-latin-c_b,
    #cat-latin-b:checked ~ .category-panels .panel-latin-b,
    #cat-latin-a:checked ~ .category-panels .panel-latin-a,
    #cat-latin-s:checked ~ .category-panels .panel-latin-s,
    #cat-latin-m:checked ~ .category-panels .panel-latin-m,
    #cat-latin-eadc:checked ~ .category-panels .panel-latin-eadc,
    #cat-latin-open:checked ~ .category-panels .panel-latin-open {
      display: block;
    }

    .interpretation {
      color: var(--ink-soft);
      font-weight: 650;
      margin-top: 2px;
    }

    .note-box {
      border-radius: 12px;
      padding: 12px 14px;
      margin-top: 10px;
    }

    .note-box {
      background: var(--note-soft);
      border: 0;
      border-left: 3px solid rgba(123, 110, 214, .28);
      color: var(--ink-soft);
    }

    .program-story {
      display: grid;
      gap: 16px;
    }

    .program-story + .program-story {
      margin-top: 22px;
      padding-top: 22px;
      border-top: 1px solid var(--line);
    }

    .story-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 12px;
    }

    .story-card {
      background: #fff;
      border-radius: 12px;
      padding: 14px;
    }

    .story-card h3 {
      color: var(--ink-soft);
      font-size: 14px;
      font-weight: 560;
      margin-bottom: 8px;
    }

    .program-heading {
      color: var(--accent-dark);
      font-size: 18px;
      font-weight: 560;
      margin: 2px 0 0;
    }

    .parent-conclusion {
      background: transparent;
      border: 0;
      border-radius: 14px;
      padding: 18px 18px 10px;
      color: var(--ink-soft);
    }

    .parent-conclusion h2 {
      color: var(--ink-soft);
      font-size: 15px;
      font-weight: 560;
      margin-bottom: 12px;
    }

    .table-wrap {
      overflow-x: auto;
      border: 1px solid var(--line);
      border-radius: 12px;
      margin-top: 10px;
    }

    .tournament-list .table-wrap {
      border: 0;
      border-radius: 0;
      margin-top: 16px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--paper);
      font-size: 12.5px;
    }

    th, td {
      border-bottom: 1px solid var(--line);
      padding: 9px 10px;
      text-align: left;
      vertical-align: top;
      overflow-wrap: anywhere;
    }

    th {
      background: #F5F2FC;
      color: #4A4568;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .04em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    tbody tr:nth-child(even) td { background: #FEFDFF; }
    tbody tr:last-child td { border-bottom: 0; }

    details {
      border: 0;
      border-top: 1px solid var(--line);
      border-radius: 0;
      background: transparent;
      padding: 18px 0;
      margin-top: 0;
    }

    details:first-child {
      border-top: 0;
    }

    summary {
      cursor: pointer;
      color: var(--ink);
      font-size: 16px;
      font-weight: 560;
    }

    .tournament-list {
      display: grid;
      gap: 0;
    }

    .tournament-summary {
      display: grid;
      grid-template-columns: minmax(92px, .35fr) minmax(180px, 1fr) minmax(180px, 1fr) minmax(120px, .45fr);
      gap: 12px;
      align-items: start;
      color: var(--ink);
    }

    .summary-title {
      font-weight: 600;
      color: var(--ink);
    }

    .summary-meta {
      color: var(--muted);
      font-size: 12px;
      margin-top: 4px;
    }

    .tournament-detail-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin: 18px 0 14px;
      padding-top: 4px;
    }

    .tournament-detail-grid .insight-card {
      background: transparent;
      border-radius: 0;
      padding: 0 18px 0 0;
      min-height: 0;
    }

    .tournament-detail-grid .insight-card + .insight-card {
      padding-left: 18px;
      border-left: 1px solid rgba(233, 229, 244, .9);
    }

    .tournament-detail-grid h3 {
      color: var(--ink);
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 8px;
    }

    .tournament-detail-grid p {
      margin-bottom: 6px;
    }

    .tournament-detail-grid strong {
      font-weight: 600;
    }

    @media (max-width: 900px) {
      .profile-grid,
      .kpi-grid,
      .insight-grid,
      .two-column,
      .three-column,
      .story-grid,
      .tournament-summary,
      .tournament-detail-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 620px) {
      .report { width: min(100% - 24px, 1080px); padding-top: 18px; }
      .cover, .section { padding: 18px; border-radius: 14px; }
      h1 { font-size: 26px; }
      .profile-grid,
      .kpi-grid,
      .insight-grid,
      .two-column,
      .three-column,
      .story-grid,
      .tournament-summary,
      .tournament-detail-grid,
      .tabs {
        grid-template-columns: 1fr;
      }
      .tabs { position: static; }
    }

    @media print {
      @page { size: A4; margin: 12mm; }
      body { background: #fff; font-size: 11px; }
      .report { width: 100%; padding: 0; }
      .tabs { position: static; padding: 0 0 10px; }
      .cover, .section {
        box-shadow: none;
        break-inside: avoid;
        page-break-inside: avoid;
        border-radius: 10px;
      }
      .tab-label { box-shadow: none; }
      h1 { font-size: 24px; }
      h2, summary { font-size: 17px; }
      table { font-size: 10px; }
      th, td { padding: 5px 6px; }
      .table-wrap { overflow: visible; }
    }
  </style>
</head>
<body>
<main class="report">
  <header class="cover">
    <div class="eyebrow">Отчёт по спортивным бальным танцам</div>
    <h1>{{ dancer.name }}</h1>
    <p class="cover-subtitle">{{ entry_label }} · Compreg IDD {{ dancer.idd }}</p>
    <div class="profile-grid">
      <div class="profile-item"><div class="label">Клуб</div><div class="value">{{ dancer.club or "не указан" }}</div></div>
      <div class="profile-item"><div class="label">Город</div><div class="value">{{ dancer.city or "не указан" }}</div></div>
      <div class="profile-item"><div class="label">Период</div><div class="value">{{ summary.date_from }} — {{ summary.date_to }}</div></div>
      <div class="profile-item"><div class="label">Режим отчёта</div><div class="value">выберите ниже</div></div>
    </div>
  </header>

  <input class="tab-input" type="radio" name="report-mode" id="tab-trainer" checked>
  <input class="tab-input" type="radio" name="report-mode" id="tab-parent">

  <nav class="tabs" aria-label="Режим просмотра отчёта">
    <label class="tab-label" for="tab-trainer">
      <span class="tab-title">Тренеру</span>
      <span class="tab-help">Разбор программ, динамики, танцев и турниров</span>
    </label>
    <label class="tab-label" for="tab-parent">
      <span class="tab-title">Родителю</span>
      <span class="tab-help">Кратко и понятно о прогрессе</span>
    </label>
  </nav>

  <section class="mode-panel parent-panel">
    <section class="section">
      <h2>Общая оценка сезона</h2>
      <p class="section-kicker">Краткая сводка по турнирам и динамике выступлений.</p>
      <div class="kpi-grid">
        <div class="card"><div class="label">Турниры</div><div class="kpi-value">{{ summary.tournaments }}</div><div class="muted">{{ summary.tournaments|pluralize("турнир", "турнира", "турниров") }} в отчёте</div></div>
        <div class="card"><div class="label">Выступления</div><div class="kpi-value">{{ summary.protocols }}</div><div class="muted">{{ summary.protocols|pluralize("выступление", "выступления", "выступлений") }}</div></div>
        <div class="card"><div class="label">Период наблюдения</div><div class="kpi-value" style="font-size:20px">{{ summary.date_from }} — {{ summary.date_to }}</div></div>
      </div>
      <div class="note-box">
        <div class="label">Общий вывод</div>
        <div class="big-status">{{ role_views.parent.season_status }}</div>
        <p>{{ role_views.parent.season_comment }}</p>
      </div>
    </section>

    <section class="section">
      <h2>Выводы по программам</h2>
      <p class="section-kicker">Стандарт и латина показаны отдельно, чтобы не смешивать разные программы.</p>
      {% for key, program in role_views.parent.programs.items() %}
      <div class="program-story">
        <h3 class="program-heading">{{ program.title|capitalize }}</h3>
        <div class="story-grid">
          <div class="story-card">
            <h4>Что получается лучше всего</h4>
            <p>{{ program.best_text }}</p>
            {% if program.best %}
            <ul class="plain-list">
              {% for item in program.best %}
                <li><strong>{{ item.dance|dance_label }}</strong><span class="muted">среднее место {{ item.final_avg_place|fmt }}</span></li>
              {% endfor %}
            </ul>
            {% endif %}
          </div>
          <div class="story-card">
            <h4>Что требует внимания</h4>
            <p>{{ program.attention_text }}</p>
            {% if program.attention %}
            <ul class="plain-list">
              {% for item in program.attention %}
                <li><strong>{{ item.dance|dance_label }}</strong><span class="muted">среднее место {{ item.final_avg_place|fmt }}</span></li>
              {% endfor %}
            </ul>
            {% endif %}
          </div>
        </div>
        <div class="story-card">
          <h4>Динамика</h4>
          <p>{{ program.trend_text }}</p>
          {% if program.attention_overlap_note %}
            <p class="muted">{{ program.attention_overlap_note }}</p>
          {% endif %}
          {% if program.limited %}
            <p class="muted">Отдельные танцы пока имеют ограниченную выборку и не влияют на основной вывод.</p>
          {% endif %}
        </div>
        <div class="parent-conclusion">
          <h2>Общий вывод</h2>
          {% for line in program.overview %}
            <p>{{ line }}</p>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </section>

    <section class="section">
      <h2>Последние турниры</h2>
      <div class="plain-list">
        {% for item in role_views.parent.latest_tournaments %}
          <li>
            <span>
              <strong>{{ item.event_date }}</strong> · {{ item.tournament_title }}
              {% if item.dance_codes %}
                <span class="muted">· {{ item.dance_codes|join(", ") }}</span>
              {% endif %}
            </span>
            <span class="muted">{{ item.protocols|pluralize("выступление", "выступления", "выступлений") }}</span>
          </li>
        {% endfor %}
      </div>
    </section>

  </section>

  <section class="mode-panel trainer-panel">
    {% for key, program in programs.items() %}
    <section class="section">
      <h2>{{ program.title|capitalize }}</h2>
      <p class="section-kicker">Категории переключаются отдельно для каждой программы. Меньшее место означает лучший результат.</p>

      {% for slice in program.category_slices %}
        <input class="category-input" type="radio" name="cat-{{ key }}" id="cat-{{ key }}-{{ slice.key }}" {{ "checked" if loop.first else "" }}>
      {% endfor %}
      <div class="category-tabs">
        {% for slice in program.category_slices %}
          <label class="category-tab" for="cat-{{ key }}-{{ slice.key }}">{{ slice.label }}</label>
        {% endfor %}
      </div>

      <div class="category-panels">
      {% for slice in program.category_slices %}
        <div class="category-panel panel-{{ key }}-{{ slice.key }}">
          {% if slice.protocol_count < 3 %}
            <div class="note-box">Ограниченная выборка: {{ slice.protocol_count|pluralize("протокол", "протокола", "протоколов") }} в этом срезе.</div>
          {% endif %}

          <div class="three-column">
            <div class="insight-card">
              <h3>Лучше по среднему месту</h3>
              {% if slice.best %}
              <ul class="plain-list">
                {% for item in slice.best %}
                  <li><strong>{{ item.dance|dance_label }}</strong><span class="muted">{{ item.final_avg_place|fmt }}</span></li>
                {% endfor %}
              </ul>
              {% else %}<p class="muted">Ограниченная выборка.</p>{% endif %}
            </div>
            <div class="insight-card">
              <h3>Требуют внимания</h3>
              {% if slice.attention %}
              <ul class="plain-list">
                {% for item in slice.attention %}
                  <li><strong>{{ item.dance|dance_label }}</strong><span class="muted">{{ item.final_avg_place|fmt }}</span></li>
                {% endfor %}
              </ul>
              {% else %}<p class="muted">Ограниченная выборка.</p>{% endif %}
            </div>
            <div class="insight-card">
              <h3>Наиболее стабильные</h3>
              {% if slice.stable %}
              <ul class="plain-list">
                {% for item in slice.stable %}
                  <li>
                    <strong>{{ item.dance|dance_label }}</strong>
                    <span class="stability-meter">
                      <span class="progress-label">{{ item.stability_label }}</span>
                      <span class="progress-track"><span class="progress-fill" style="{{ item.stability_style }}"></span></span>
                    </span>
                  </li>
                {% endfor %}
              </ul>
              {% else %}<p class="muted">Ограниченная выборка.</p>{% endif %}
            </div>
          </div>

          <div class="three-column" style="margin-top:12px">
            <div class="insight-card">
              <h3>Улучшается</h3>
              {% if slice.improving %}
                <ul class="plain-list">{% for item in slice.improving %}<li><strong>{{ item.dance|dance_label }}</strong><span class="muted">{{ item.first_avg_place|fmt }} → {{ item.last_avg_place|fmt }}</span></li>{% endfor %}</ul>
              {% else %}<p class="muted">{{ "Для уверенного вывода пока мало наблюдений." if not slice.enough_data else "Явного улучшения по тренду сейчас не видно." }}</p>{% endif %}
            </div>
            <div class="insight-card">
              <h3>Требует внимания по динамике</h3>
              {% if slice.declining %}
                <ul class="plain-list">{% for item in slice.declining %}<li><strong>{{ item.dance|dance_label }}</strong><span class="muted">{{ item.first_avg_place|fmt }} → {{ item.last_avg_place|fmt }}</span></li>{% endfor %}</ul>
              {% else %}<p class="muted">{{ "Для уверенного вывода пока мало наблюдений." if not slice.enough_data else "Тревожной динамики по тренду сейчас не видно." }}</p>{% endif %}
            </div>
            <div class="insight-card">
              <h3>Стабильно</h3>
              {% if slice.stable_trends %}
                <ul class="plain-list">{% for item in slice.stable_trends %}<li><strong>{{ item.dance|dance_label }}</strong><span class="muted">{{ item.first_avg_place|fmt }} → {{ item.last_avg_place|fmt }}</span></li>{% endfor %}</ul>
              {% else %}<p class="muted">{{ "Для уверенного вывода пока мало наблюдений." if not slice.enough_data else "Отдельной группы стабильной динамики сейчас не выделяется." }}</p>{% endif %}
            </div>
          </div>

          <h3 style="margin-top:18px">Танцы</h3>
          <p class="section-kicker">Стабильность показывает, насколько сильно меняется итоговое место танца от турнира к турниру. Чем меньше колебания, тем выше стабильность.</p>
          <div class="table-wrap">
            <table>
              <thead><tr><th>Танец</th><th class="number">Среднее место</th><th class="number">Лучшее место</th><th>Стабильность</th></tr></thead>
              <tbody>
              {% for item in slice.metrics %}
                <tr>
                  <td><strong>{{ item.dance|dance_label }}</strong></td>
                  <td class="number">{{ item.final_avg_place|fmt }}</td>
                  <td class="number">{{ item.best_place|fmt }}</td>
                  <td>
                    <div class="progress-label">{{ item.stability_label }}</div>
                    <div class="progress-track"><div class="progress-fill" style="{{ item.stability_style }}"></div></div>
                  </td>
                </tr>
              {% endfor %}
              {% if not slice.metrics %}
                <tr><td colspan="4">Ограниченная выборка.</td></tr>
              {% endif %}
              </tbody>
            </table>
          </div>

        </div>
      {% endfor %}
      </div>
      <div class="note-box">Расчёт стабильности основан на разбросе итоговых мест по турнирам. Полная шкала означает очень устойчивый результат, короткая шкала — сильные колебания.</div>
    </section>
    {% endfor %}

    <section class="section">
      <details>
        <summary>Дополнительная аналитика судей</summary>
        <p class="section-kicker">В рейтинг включены только судьи, по которым доступно не менее 10 оценок.</p>
        <div class="two-column">
          <div>
            <h3>Более строгие судьи</h3>
            <div class="table-wrap">
              <table>
                <thead><tr><th>Судья</th><th>Интерпретация</th><th class="number">Оценок</th></tr></thead>
                <tbody>
                {% if judges.strictest %}
                {% for item in judges.strictest %}
                  <tr><td>{{ item.judge }}</td><td><div class="interpretation">{{ item.judge_label }}</div><div class="tiny">отклонение от панели: {{ item.avg_deviation|fmt }}</div></td><td class="number">{{ item.n_marks|pluralize("оценка", "оценки", "оценок") }}</td></tr>
                {% endfor %}
                {% else %}
                  <tr><td colspan="3">Недостаточно данных для формирования рейтинга судей.</td></tr>
                {% endif %}
                </tbody>
              </table>
            </div>
          </div>
          <div>
            <h3>Более мягкие судьи</h3>
            <div class="table-wrap">
              <table>
                <thead><tr><th>Судья</th><th>Интерпретация</th><th class="number">Оценок</th></tr></thead>
                <tbody>
                {% if judges.softest %}
                {% for item in judges.softest %}
                  <tr><td>{{ item.judge }}</td><td><div class="interpretation">{{ item.judge_label }}</div><div class="tiny">отклонение от панели: {{ item.avg_deviation|fmt }}</div></td><td class="number">{{ item.n_marks|pluralize("оценка", "оценки", "оценок") }}</td></tr>
                {% endfor %}
                {% else %}
                  <tr><td colspan="3">Недостаточно данных для формирования рейтинга судей.</td></tr>
                {% endif %}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </details>
    </section>

    <section class="section">
      <h2>Турниры</h2>
      <div class="two-column">
        <div class="insight-card">
          <h3>Лучшие турниры</h3>
          <ul class="plain-list">
            {% for item in role_views.trainer.best_tournaments %}
              <li><span><strong>{{ item.event_date }}</strong> · {{ item.tournament_title }}</span><span class="muted">{{ item.avg_place|fmt }}</span></li>
            {% endfor %}
          </ul>
        </div>
        <div class="insight-card">
          <h3>Наиболее сложные турниры</h3>
          <ul class="plain-list">
            {% for item in role_views.trainer.hardest_tournaments %}
              <li><span><strong>{{ item.event_date }}</strong> · {{ item.tournament_title }}</span><span class="muted">{{ item.avg_place|fmt }}</span></li>
            {% endfor %}
          </ul>
        </div>
      </div>
      <h3 style="margin-top:18px">Полный список турниров</h3>
      <div class="tournament-list">
        {% for item in trainer_tournament_summaries %}
        <details>
          <summary>
            <div class="tournament-summary">
              <div>
                <div class="label">Дата</div>
                <div class="summary-title">{{ item.event_date }}</div>
              </div>
              <div>
                <div class="label">Турнир</div>
                <div class="summary-title">{{ item.tournament_title }}</div>
              </div>
              <div>
                <div class="label">Категория / программа</div>
                <div class="summary-meta">{{ item.categories|join("; ") }}</div>
                <div class="summary-meta">{{ item.programs|map("program_label")|join(", ") }}</div>
              </div>
              <div>
                <div class="label">Итоговый результат</div>
                <div class="summary-title">{{ item.protocols|pluralize("протокол", "протокола", "протоколов") }}</div>
              </div>
            </div>
          </summary>
          <div class="tournament-detail-grid">
            {% for program in item.program_summaries %}
              <div class="insight-card">
                <h3>{{ program.program_label }}</h3>
                <p class="muted">
                  Общий итог:
                  {% if program.overall.avg_place is not none %}
                    среднее место {{ program.overall.avg_place|fmt }} · {{ program.overall.dance_codes|join(", ") }}
                  {% else %}
                    {{ program.overall.dance_codes|join(", ") }} · {{ program.metric_label or "по оценкам судей" }}
                  {% endif %}
                </p>
                {% if program.display_mode == "best_worst" %}
                  {% if program.metric_type == "cross_count" %}
                    <p><strong>{% if program.best_dances|length > 1 %}Лучшие танцы{% else %}Лучший танец{% endif %}:</strong> {{ program.best_dances|map(attribute="dance_code")|join(", ") }} <span class="muted">— {{ program.best_dance.interpretation }} · {{ program.best_dance.cross_count }} крестов</span></p>
                    <p><strong>{% if program.worst_dances|length > 1 %}Требуют внимания{% else %}Требует внимания{% endif %}:</strong> {{ program.worst_dances|map(attribute="dance_code")|join(", ") }} <span class="muted">— {{ program.worst_dance.interpretation }} · {{ program.worst_dance.cross_count }} крестов</span></p>
                  {% else %}
                    <p><strong>{% if program.best_dances|length > 1 %}Лучшие танцы{% else %}Лучший танец{% endif %}:</strong> {{ program.best_dances|map(attribute="dance_code")|join(", ") }} <span class="muted">место {{ program.best_dance.final_place|fmt }}</span></p>
                    <p><strong>{% if program.worst_dances|length > 1 %}Требуют внимания{% else %}Требует внимания{% endif %}:</strong> {{ program.worst_dances|map(attribute="dance_code")|join(", ") }} <span class="muted">место {{ program.worst_dance.final_place|fmt }}</span></p>
                  {% endif %}
                {% elif program.display_mode == "single_dance" and program.evaluated_dance %}
                  {% if program.metric_type == "cross_count" %}
                    <p><strong>Оценённый танец:</strong> {{ program.evaluated_dance.dance_code }} <span class="muted">— {{ program.evaluated_dance.cross_count }} крестов</span></p>
                  {% else %}
                    <p><strong>Оценённый танец:</strong> {{ program.evaluated_dance.dance_code }} <span class="muted">— место {{ program.evaluated_dance.final_place|fmt }}</span></p>
                  {% endif %}
                {% elif program.display_mode == "tied" %}
                  {% if program.metric_type == "cross_count" %}
                    <p><strong>Танцы оценены примерно одинаково:</strong> {{ program.tied_dances|join(", ") }} <span class="muted">— {{ program.tied_metric_value }} крестов</span></p>
                  {% else %}
                    <p><strong>Танцы оценены примерно одинаково:</strong> {{ program.tied_dances|join(", ") }} <span class="muted">— среднее место {{ program.tied_metric_value|fmt }}</span></p>
                  {% endif %}
                {% else %}
                  <p class="muted">Недостаточно данных для лучшего и худшего танца.</p>
                {% endif %}
              </div>
            {% endfor %}
          </div>
          <div class="table-wrap">
            <table>
              <thead><tr><th>Танец</th><th>Программа</th><th class="number">Итоговое место</th><th class="number">Протоколов</th></tr></thead>
              <tbody>
              {% for result in item.dance_results %}
                <tr>
                  <td><strong>{{ result.dance_code or (result.dance|dance_code) }}</strong></td>
                  <td>{{ result.program|program_label }}</td>
                  <td class="number">{{ result.final_place|fmt }}</td>
                  <td class="number">{{ result.n_results|pluralize("протокол", "протокола", "протоколов") }}</td>
                </tr>
              {% endfor %}
              </tbody>
            </table>
          </div>
        </details>
        {% endfor %}
      </div>
    </section>

  </section>
</main>
</body>
</html>
