{% macro icon(name, extra_class="") -%}
<span class="status-icon {{ extra_class }}" aria-hidden="true">
  {% if name == "star" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="m12 3 2.7 5.47 6.03.88-4.36 4.25 1.03 6-5.4-2.84-5.4 2.84 1.03-6-4.36-4.25 6.03-.88L12 3Z"/></svg>
  {% elif name == "alert" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.3 4.2 2.8 17.4A2 2 0 0 0 4.5 20h15a2 2 0 0 0 1.7-2.6L13.7 4.2a2 2 0 0 0-3.4 0Z"/></svg>
  {% elif name == "info" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="M12 11v5"/><path d="M12 8h.01"/><circle cx="12" cy="12" r="9"/></svg>
  {% elif name == "equal" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="M6 9h12"/><path d="M6 15h12"/></svg>
  {% elif name == "up" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="M12 19V5"/><path d="m6 11 6-6 6 6"/></svg>
  {% elif name == "down" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14"/><path d="m18 13-6 6-6-6"/></svg>
  {% elif name == "chevron" %}
  <svg viewBox="0 0 24 24" fill="none"><path d="m6 9 6 6 6-6"/></svg>
  {% endif %}
</span>
{%- endmacro %}
<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Отчёт танцора · {{ dancer.name }} · {{ dancer.idd }}</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #F8F7FC;
      --paper: #FFFFFF;
      --paper-soft: #FDFBFF;
      --ink: #20212A;
      --ink-soft: #3D3F4C;
      --muted: #727488;
      --line: #E9E5F4;
      --accent: #7B6ED6;
      --accent-dark: #5E51B8;
      --accent-soft: #F0EDFB;
      --accent-light: #FAF8FF;
      --note-soft: #F6F4FC;
      --success-soft: #EAF6F1;
      --accent-positive: #4F8F78;
      --accent-positive-bg: #F1F8F5;
      --accent-warning: #9A7745;
      --accent-warning-bg: #FFF8EA;
      --accent-attention: #B27670;
      --accent-attention-bg: #FCF2F0;
      --accent-neutral: #7A7692;
      --accent-neutral-bg: #F5F3FA;
      --shadow: 0 10px 26px rgba(49, 42, 96, .055);
      --radius-control: 999px;
      --radius-card: 14px;
      --radius-panel: 12px;
      --radius-section: 18px;
      --radius-circle: 999px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--ink);
      font: 14px/1.62 Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
    }

    .report {
      width: min(1080px, calc(100% - 40px));
      margin: 0 auto;
      padding: 34px 0 64px;
    }

    .cover {
      background: linear-gradient(135deg, var(--paper) 0%, var(--accent-light) 100%);
      border: 1px solid var(--line);
      border-radius: var(--radius-section);
      box-shadow: var(--shadow);
      padding: 34px 36px 28px;
      margin-bottom: 18px;
    }

    .eyebrow {
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 620;
      letter-spacing: .08em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    h1, h2, h3, h4 { margin: 0; line-height: 1.2; letter-spacing: 0; }
    h1 { font-size: 34px; max-width: 760px; font-weight: 660; }
    h2 { font-size: 21px; margin-bottom: 12px; font-weight: 600; }
    h3 { font-size: 16px; margin: 0 0 10px; font-weight: 560; color: var(--ink-soft); }
    h4 { font-size: 13px; margin: 0 0 8px; font-weight: 560; color: var(--ink-soft); }
    p { margin: 0 0 10px; }

    .cover-subtitle {
      color: var(--ink-soft);
      font-size: 16px;
      margin-top: 8px;
    }

    .header-filter-panel {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, auto);
      gap: 14px;
      align-items: center;
      margin-top: 22px;
      padding-top: 18px;
      border-top: 1px solid rgba(233, 229, 244, .78);
    }

    .header-city-filter {
      min-width: 0;
    }

    .header-date-filter {
      display: grid;
      grid-template-columns: minmax(136px, 1fr) auto minmax(136px, 1fr);
      gap: 8px;
      align-items: center;
      justify-self: end;
    }

    .date-separator {
      color: var(--muted);
      font-size: 13px;
    }

    .profile-grid,
    .kpi-grid,
    .insight-grid,
    .two-column,
    .three-column {
      display: grid;
      gap: 12px;
    }

    .profile-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); margin-top: 22px; }
    .kpi-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .insight-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .two-column { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .three-column { grid-template-columns: repeat(3, minmax(0, 1fr)); }

    .profile-item,
    .card,
    .insight-card {
      background: rgba(255, 255, 255, .62);
      border-radius: var(--radius-card);
      padding: 14px;
      break-inside: avoid;
    }

    .profile-item,
    .card {
      border: 1px solid rgba(109, 91, 208, .11);
    }

    .insight-card {
      border: 0;
    }

    .insight-card.positive {
      background: var(--accent-positive-bg);
    }

    .insight-card.attention {
      background: var(--accent-attention-bg);
    }

    .insight-card.neutral {
      background: var(--accent-neutral-bg);
    }

    .insight-card h3 {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .insight-card h3 .status-icon {
      width: 32px;
      height: 32px;
      flex-basis: 32px;
      margin-left: auto;
    }

    .status-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: var(--radius-circle);
      background: var(--accent-neutral-bg);
      color: var(--accent-neutral);
      flex: 0 0 24px;
      margin-right: 2px;
      line-height: 0;
    }

    .status-icon svg {
      width: 15px;
      height: 15px;
      stroke: currentColor;
      stroke-width: 1.9;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .insight-card h3 .status-icon svg {
      width: 18px;
      height: 18px;
    }

    .status-icon.positive,
    .positive .status-icon {
      background: var(--accent-positive-bg);
      color: var(--accent-positive);
    }

    .status-icon.attention,
    .attention .status-icon {
      background: var(--accent-attention-bg);
      color: var(--accent-attention);
    }

    .status-icon.neutral,
    .neutral .status-icon,
    .limited-note .status-icon {
      background: var(--accent-neutral-bg);
      color: var(--accent-neutral);
    }

    .label {
      color: var(--muted);
      font-size: 11px;
      font-weight: 560;
      letter-spacing: .06em;
      text-transform: uppercase;
    }

    .value {
      color: var(--ink);
      font-weight: 600;
      margin-top: 4px;
      overflow-wrap: anywhere;
    }

    .tabs {
      position: sticky;
      top: 0;
      z-index: 5;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      background: rgba(248, 247, 252, .94);
      backdrop-filter: blur(8px);
      padding: 10px 0 18px;
      margin-bottom: 12px;
    }

    .tab-input { position: absolute; opacity: 0; pointer-events: none; }
    .category-input { position: absolute; opacity: 0; pointer-events: none; }

    .tab-label {
      display: flex;
      flex-direction: column;
      gap: 3px;
      cursor: pointer;
      border: 1px solid var(--line);
      border-radius: var(--radius-card);
      background: var(--paper);
      color: var(--ink-soft);
      padding: 15px 18px;
      box-shadow: 0 6px 18px rgba(49, 42, 96, .04);
      transition: all .18s ease;
    }

    .tab-title {
      font-size: 16px;
      font-weight: 600;
    }

    .tab-help {
      color: var(--muted);
      font-size: 12px;
    }

    #tab-parent:checked ~ .tabs label[for="tab-parent"],
    #tab-trainer:checked ~ .tabs label[for="tab-trainer"] {
      background: var(--accent-soft);
      border-color: rgba(94, 81, 184, .42);
      color: var(--accent-dark);
      box-shadow: 0 6px 16px rgba(77, 61, 181, .07);
    }

    #tab-parent:checked ~ .tabs label[for="tab-parent"] .tab-help,
    #tab-trainer:checked ~ .tabs label[for="tab-trainer"] .tab-help {
      color: var(--muted);
    }

    .mode-panel { display: none; }
    #tab-parent:checked ~ .parent-panel { display: block; }
    #tab-trainer:checked ~ .trainer-panel { display: block; }

    .report-filters {
      background: var(--paper);
      border: 1px solid rgba(233, 229, 244, .78);
      border-radius: var(--radius-section);
      box-shadow: 0 6px 18px rgba(49, 42, 96, .03);
      margin: 0 0 24px;
      padding: 18px;
    }

    .filter-grid {
      display: grid;
      grid-template-columns: minmax(220px, 1.4fr) minmax(220px, 1fr);
      gap: 18px;
      align-items: start;
    }

    .filter-title {
      color: var(--ink-soft);
      font-size: 13px;
      font-weight: 560;
      margin-bottom: 8px;
    }

    .filter-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .filter-chip,
    .city-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border: 1px solid var(--line);
      border-radius: var(--radius-control);
      background: var(--accent-light);
      color: var(--ink-soft);
      cursor: pointer;
      font-size: 12px;
      padding: 7px 10px;
    }

    .city-chip {
      appearance: none;
      font: inherit;
      line-height: 1.2;
      transition: background .16s ease, border-color .16s ease, color .16s ease;
    }

    .city-chip[aria-pressed="true"] {
      background: var(--accent-soft);
      border-color: rgba(94, 81, 184, .38);
      color: var(--accent-dark);
    }

    .filter-chip input {
      accent-color: var(--accent);
      margin: 0;
    }

    .date-filter-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .date-filter-grid input,
    .header-date-filter input {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: var(--radius-control);
      color: var(--ink-soft);
      font: inherit;
      font-size: 13px;
      min-height: 34px;
      padding: 7px 12px;
    }

    .filter-note {
      margin: 12px 0 0;
      color: var(--muted);
      font-size: 12px;
    }

    .filter-empty {
      display: none;
      color: var(--muted);
      margin-top: 12px;
    }

    .section {
      background: var(--paper);
      border: 1px solid rgba(233, 229, 244, .78);
      border-radius: var(--radius-section);
      box-shadow: 0 6px 18px rgba(49, 42, 96, .035);
      margin: 24px 0;
      padding: 24px;
      break-inside: avoid;
    }

    .section-kicker {
      color: var(--muted);
      font-size: 13px;
      max-width: 720px;
      margin-bottom: 14px;
    }

    .kpi-value,
    .big-status {
      color: var(--accent-dark);
      font-size: 26px;
      font-weight: 600;
      line-height: 1.05;
      margin-top: 8px;
    }

    .big-status { font-size: 23px; }

    .card {
      background: #FBFAFF;
      min-height: 110px;
    }

    .insight-card {
      background: var(--accent-light);
      min-height: 120px;
    }

    .rank-list,
    .plain-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 8px;
    }

    .rank-list li,
    .plain-list li {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      border-radius: var(--radius-panel);
      background: transparent;
      padding: 7px 0;
    }

    .rank-list li + li,
    .plain-list li + li {
      border-top: 1px solid rgba(233, 229, 244, .68);
    }

    .rank {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 28px;
      height: 28px;
      border-radius: var(--radius-circle);
      background: var(--accent);
      color: #fff;
      font-weight: 650;
      margin-right: 8px;
    }

    .muted { color: var(--muted); }
    .tiny { color: var(--muted); font-size: 11px; margin-top: 3px; }
    .number { text-align: right; white-space: nowrap; }

    .progress-label {
      display: block;
      color: var(--ink-soft);
      font-size: 12px;
      font-weight: 560;
      margin-bottom: 6px;
    }

    .stability-meter {
      display: block;
      flex: 0 0 132px;
      width: 132px;
      max-width: 46%;
    }

    .progress-track {
      display: block;
      width: 100%;
      min-width: 92px;
      height: 7px;
      border-radius: var(--radius-control);
      background: #ECE8F6;
      overflow: hidden;
    }

    .progress-fill {
      display: block;
      height: 100%;
      width: var(--stability-width, 0%);
      border-radius: inherit;
      background: linear-gradient(90deg, var(--accent-dark), var(--accent));
    }

    .category-chip-groups {
      display: grid;
      gap: 13px;
      margin: 16px 0 22px;
    }

    .category-chip-group {
      display: grid;
      gap: 7px;
    }

    .category-group-title {
      color: var(--muted);
      font-size: 11px;
      font-weight: 560;
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    .category-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 0;
    }

    .category-tab {
      cursor: pointer;
      border: 1px solid var(--line);
      border-radius: var(--radius-control);
      background: var(--paper);
      color: var(--ink-soft);
      padding: 8px 12px;
      font-size: 12px;
      font-weight: 560;
    }

    .category-tab.limited {
      color: var(--accent-neutral);
      background: var(--accent-neutral-bg);
      border-color: #DCD6EA;
      border-style: dashed;
      font-weight: 520;
    }

    .chip-badge {
      display: inline-flex;
      margin-left: 6px;
      border-radius: var(--radius-control);
      background: #E4DFF0;
      color: var(--accent-neutral);
      font-size: 10px;
      font-weight: 560;
      padding: 2px 6px;
      vertical-align: middle;
    }

    .category-panel { display: none; padding-top: 2px; }
    .parent-category-panel { display: none; padding-top: 2px; }

    .category-panel > .note-box:first-child,
    .category-panel > .section-kicker:first-child {
      margin-top: 0;
    }

    .note-box + .three-column,
    .section-kicker + .note-box,
    .category-panel .three-column + .three-column {
      margin-top: 14px;
    }

    .dance-table-heading {
      margin-top: 22px;
    }

    #parent-cat-standard-all:checked ~ .category-chip-groups label[for="parent-cat-standard-all"],
    #parent-cat-standard-n_e:checked ~ .category-chip-groups label[for="parent-cat-standard-n_e"],
    #parent-cat-standard-e_d:checked ~ .category-chip-groups label[for="parent-cat-standard-e_d"],
    #parent-cat-standard-eadc:checked ~ .category-chip-groups label[for="parent-cat-standard-eadc"],
    #parent-cat-latin-all:checked ~ .category-chip-groups label[for="parent-cat-latin-all"],
    #parent-cat-latin-n_e:checked ~ .category-chip-groups label[for="parent-cat-latin-n_e"],
    #parent-cat-latin-e_d:checked ~ .category-chip-groups label[for="parent-cat-latin-e_d"],
    #parent-cat-latin-eadc:checked ~ .category-chip-groups label[for="parent-cat-latin-eadc"] {
      background: var(--accent-soft);
      border-color: rgba(94, 81, 184, .38);
      color: var(--accent-dark);
    }

    #parent-cat-standard-all:checked ~ .parent-category-panels .parent-panel-standard-all,
    #parent-cat-standard-n_e:checked ~ .parent-category-panels .parent-panel-standard-n_e,
    #parent-cat-standard-e_d:checked ~ .parent-category-panels .parent-panel-standard-e_d,
    #parent-cat-standard-eadc:checked ~ .parent-category-panels .parent-panel-standard-eadc,
    #parent-cat-latin-all:checked ~ .parent-category-panels .parent-panel-latin-all,
    #parent-cat-latin-n_e:checked ~ .parent-category-panels .parent-panel-latin-n_e,
    #parent-cat-latin-e_d:checked ~ .parent-category-panels .parent-panel-latin-e_d,
    #parent-cat-latin-eadc:checked ~ .parent-category-panels .parent-panel-latin-eadc {
      display: block;
    }

    #cat-standard-all:checked ~ .category-chip-groups label[for="cat-standard-all"],
    #cat-standard-n:checked ~ .category-chip-groups label[for="cat-standard-n"],
    #cat-standard-n_e:checked ~ .category-chip-groups label[for="cat-standard-n_e"],
    #cat-standard-e:checked ~ .category-chip-groups label[for="cat-standard-e"],
    #cat-standard-e_d:checked ~ .category-chip-groups label[for="cat-standard-e_d"],
    #cat-standard-d:checked ~ .category-chip-groups label[for="cat-standard-d"],
    #cat-standard-d_c:checked ~ .category-chip-groups label[for="cat-standard-d_c"],
    #cat-standard-c:checked ~ .category-chip-groups label[for="cat-standard-c"],
    #cat-standard-c_b:checked ~ .category-chip-groups label[for="cat-standard-c_b"],
    #cat-standard-b:checked ~ .category-chip-groups label[for="cat-standard-b"],
    #cat-standard-a:checked ~ .category-chip-groups label[for="cat-standard-a"],
    #cat-standard-s:checked ~ .category-chip-groups label[for="cat-standard-s"],
    #cat-standard-m:checked ~ .category-chip-groups label[for="cat-standard-m"],
    #cat-standard-eadc:checked ~ .category-chip-groups label[for="cat-standard-eadc"],
    #cat-standard-open:checked ~ .category-chip-groups label[for="cat-standard-open"],
    #cat-latin-all:checked ~ .category-chip-groups label[for="cat-latin-all"],
    #cat-latin-n:checked ~ .category-chip-groups label[for="cat-latin-n"],
    #cat-latin-n_e:checked ~ .category-chip-groups label[for="cat-latin-n_e"],
    #cat-latin-e:checked ~ .category-chip-groups label[for="cat-latin-e"],
    #cat-latin-e_d:checked ~ .category-chip-groups label[for="cat-latin-e_d"],
    #cat-latin-d:checked ~ .category-chip-groups label[for="cat-latin-d"],
    #cat-latin-d_c:checked ~ .category-chip-groups label[for="cat-latin-d_c"],
    #cat-latin-c:checked ~ .category-chip-groups label[for="cat-latin-c"],
    #cat-latin-c_b:checked ~ .category-chip-groups label[for="cat-latin-c_b"],
    #cat-latin-b:checked ~ .category-chip-groups label[for="cat-latin-b"],
    #cat-latin-a:checked ~ .category-chip-groups label[for="cat-latin-a"],
    #cat-latin-s:checked ~ .category-chip-groups label[for="cat-latin-s"],
    #cat-latin-m:checked ~ .category-chip-groups label[for="cat-latin-m"],
    #cat-latin-eadc:checked ~ .category-chip-groups label[for="cat-latin-eadc"],
    #cat-latin-open:checked ~ .category-chip-groups label[for="cat-latin-open"] {
      background: var(--accent-soft);
      border-color: rgba(94, 81, 184, .38);
      color: var(--accent-dark);
    }

    #cat-standard-all:checked ~ .category-panels .panel-standard-all,
    #cat-standard-n:checked ~ .category-panels .panel-standard-n,
    #cat-standard-n_e:checked ~ .category-panels .panel-standard-n_e,
    #cat-standard-e:checked ~ .category-panels .panel-standard-e,
    #cat-standard-e_d:checked ~ .category-panels .panel-standard-e_d,
    #cat-standard-d:checked ~ .category-panels .panel-standard-d,
    #cat-standard-d_c:checked ~ .category-panels .panel-standard-d_c,
    #cat-standard-c:checked ~ .category-panels .panel-standard-c,
    #cat-standard-c_b:checked ~ .category-panels .panel-standard-c_b,
    #cat-standard-b:checked ~ .category-panels .panel-standard-b,
    #cat-standard-a:checked ~ .category-panels .panel-standard-a,
    #cat-standard-s:checked ~ .category-panels .panel-standard-s,
    #cat-standard-m:checked ~ .category-panels .panel-standard-m,
    #cat-standard-eadc:checked ~ .category-panels .panel-standard-eadc,
    #cat-standard-open:checked ~ .category-panels .panel-standard-open,
    #cat-latin-all:checked ~ .category-panels .panel-latin-all,
    #cat-latin-n:checked ~ .category-panels .panel-latin-n,
    #cat-latin-n_e:checked ~ .category-panels .panel-latin-n_e,
    #cat-latin-e:checked ~ .category-panels .panel-latin-e,
    #cat-latin-e_d:checked ~ .category-panels .panel-latin-e_d,
    #cat-latin-d:checked ~ .category-panels .panel-latin-d,
    #cat-latin-d_c:checked ~ .category-panels .panel-latin-d_c,
    #cat-latin-c:checked ~ .category-panels .panel-latin-c,
    #cat-latin-c_b:checked ~ .category-panels .panel-latin-c_b,
    #cat-latin-b:checked ~ .category-panels .panel-latin-b,
    #cat-latin-a:checked ~ .category-panels .panel-latin-a,
    #cat-latin-s:checked ~ .category-panels .panel-latin-s,
    #cat-latin-m:checked ~ .category-panels .panel-latin-m,
    #cat-latin-eadc:checked ~ .category-panels .panel-latin-eadc,
    #cat-latin-open:checked ~ .category-panels .panel-latin-open {
      display: block;
    }

    .interpretation {
      color: var(--ink-soft);
      font-weight: 650;
      margin-top: 2px;
    }

    .note-box {
      border-radius: var(--radius-panel);
      padding: 12px 14px;
      margin-top: 10px;
    }

    .note-box {
      background: var(--note-soft);
      border: 0;
      color: var(--ink-soft);
    }

    .note-box.limited-note {
      background: var(--accent-neutral-bg);
    }

    .program-story {
      display: grid;
      gap: 16px;
    }

    .program-story + .program-story {
      margin-top: 22px;
      padding-top: 22px;
      border-top: 1px solid var(--line);
    }

    .story-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      margin-top: 14px;
    }

    .story-card {
      background: transparent;
      border-radius: 0;
      padding: 0;
    }

    .story-card h3,
    .story-card h4 {
      color: var(--ink-soft);
      font-size: 14px;
      font-weight: 560;
      margin-bottom: 8px;
    }

    .story-card p {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.58;
    }

    .program-heading {
      color: var(--accent-dark);
      font-size: 18px;
      font-weight: 560;
      margin: 2px 0 0;
    }

    .parent-conclusion {
      background: transparent;
      border: 0;
      border-radius: var(--radius-card);
      padding: 14px 0 0;
      color: var(--ink-soft);
    }

    .parent-conclusion h2 {
      color: var(--ink-soft);
      font-size: 14px;
      font-weight: 560;
      margin-bottom: 10px;
    }

    .table-wrap,
    .table-scroll {
      max-width: 100%;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      border: 1px solid var(--line);
      border-radius: var(--radius-panel);
      margin-top: 10px;
    }

    .tournament-list .table-wrap,
    .tournament-list .table-scroll {
      border: 0;
      border-radius: 0;
      margin-top: 16px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--paper);
      font-size: 12.5px;
    }

    .table-scroll table {
      min-width: 640px;
    }

    .tournament-list .table-scroll table {
      min-width: 640px;
    }

    th, td {
      border-bottom: 1px solid var(--line);
      padding: 10px 14px;
      text-align: left;
      vertical-align: top;
      overflow-wrap: anywhere;
    }

    th {
      background: #F5F2FC;
      color: #4A4568;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .04em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    tbody tr:nth-child(even) td { background: #FEFDFF; }
    tbody tr:last-child td { border-bottom: 0; }

    .col-dance { min-width: 170px; }
    .col-program { min-width: 110px; }
    .col-avg { min-width: 118px; }
    .col-best { min-width: 104px; }
    .col-place { min-width: 118px; }
    .col-protocols { min-width: 108px; }
    .col-stability {
      min-width: 190px;
      padding-left: 22px;
    }

    th.col-stability,
    td.col-stability {
      text-align: left;
    }

    .col-stability .progress-track {
      max-width: 148px;
    }

    details {
      border: 0;
      border-top: 1px solid var(--line);
      border-radius: 0;
      background: transparent;
      padding: 18px 0;
      margin-top: 0;
    }

    details:first-child {
      border-top: 0;
    }

    summary {
      cursor: pointer;
      color: var(--ink);
      font-size: 16px;
      font-weight: 560;
      list-style: none;
    }

    summary::-webkit-details-marker {
      display: none;
    }

    .tournament-list {
      display: grid;
      gap: 0;
    }

    .tournament-summary-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 12px;
      align-items: center;
    }

    .tournament-summary {
      display: grid;
      grid-template-columns: minmax(92px, .35fr) minmax(180px, 1.1fr) minmax(180px, 1fr);
      gap: 12px;
      align-items: start;
      color: var(--ink);
      min-width: 0;
    }

    .accordion-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 30px;
      height: 30px;
      border-radius: var(--radius-circle);
      background: var(--accent-light);
      color: var(--accent-dark);
      flex: 0 0 auto;
      line-height: 0;
      transform-origin: 50% 50%;
      transition: transform .18s ease, background .18s ease;
    }

    .accordion-icon .status-icon {
      width: 18px;
      height: 18px;
      flex-basis: 18px;
      margin: 0;
      background: transparent;
      color: inherit;
    }

    .accordion-icon svg {
      width: 18px;
      height: 18px;
      stroke-width: 2;
    }

    details[open] .accordion-icon {
      transform: rotate(180deg);
      background: var(--accent-soft);
    }

    .tournament-title-line {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      min-width: 0;
    }

    .tournament-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      border-radius: var(--radius-control);
      background: var(--accent-positive-bg);
      color: var(--accent-positive);
      font-size: 10.5px;
      font-weight: 560;
      line-height: 1.2;
      padding: 3px 7px;
      white-space: nowrap;
    }

    .tournament-badge .status-icon {
      width: 15px;
      height: 15px;
      flex-basis: 15px;
      margin: 0;
      background: transparent;
      color: currentColor;
    }

    .tournament-badge .status-icon svg {
      width: 13px;
      height: 13px;
      stroke-width: 2;
    }

    .tournament-badge.hardest {
      color: var(--accent-attention);
      background: var(--accent-attention-bg);
    }

    .summary-title {
      font-weight: 600;
      color: var(--ink);
    }

    .summary-meta {
      color: var(--muted);
      font-size: 12px;
      margin-top: 4px;
    }

    .tournament-detail-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin: 18px 0 14px;
      padding-top: 4px;
    }

    .tournament-program-summary {
      min-width: 0;
    }

    .tournament-detail-grid .insight-card {
      background: transparent;
      border-radius: 0;
      padding: 0 18px 0 0;
      min-height: 0;
    }

    .tournament-detail-grid .insight-card + .insight-card {
      padding-left: 18px;
      border-left: 1px solid rgba(233, 229, 244, .9);
    }

    .tournament-detail-grid h3 {
      color: var(--ink);
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 8px;
    }

    .tournament-detail-grid p {
      margin-bottom: 6px;
    }

    .tournament-detail-grid strong {
      font-weight: 600;
    }

    @media (max-width: 900px) {
      .profile-grid,
      .kpi-grid,
      .insight-grid,
      .two-column,
      .three-column,
      .story-grid,
      .tournament-summary,
      .tournament-detail-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 620px) {
      .report { width: min(100% - 24px, 1080px); padding-top: 18px; }
      .cover, .section { padding: 18px; border-radius: var(--radius-card); }
      h1 { font-size: 26px; }
      .cover-subtitle { font-size: 14px; }
      .profile-grid,
      .kpi-grid,
      .insight-grid,
      .two-column,
      .three-column,
      .story-grid,
      .tournament-summary,
      .tournament-detail-grid,
      .tabs {
        grid-template-columns: 1fr;
      }
      .tabs { position: static; }
      .filter-grid,
      .date-filter-grid { grid-template-columns: 1fr; }
      .header-filter-panel {
        grid-template-columns: 1fr;
        gap: 12px;
      }
      .header-date-filter {
        grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
        justify-self: stretch;
      }
      .header-date-filter input {
        min-width: 0;
      }
      .tournament-summary-row {
        grid-template-columns: minmax(0, 1fr) auto;
      }
      .table-scroll {
        width: 100%;
        margin-left: 0;
        margin-right: 0;
      }
      .tournament-detail-grid .insight-card {
        padding: 0;
      }
      .tournament-detail-grid .insight-card + .insight-card {
        padding-left: 0;
        border-left: 0;
        padding-top: 14px;
        border-top: 1px solid rgba(233, 229, 244, .72);
      }
      .rank-list li,
      .plain-list li {
        align-items: flex-start;
      }
    }

    @media print {
      @page { size: A4; margin: 12mm; }
      body { background: #fff; font-size: 11px; }
      .report { width: 100%; padding: 0; }
      .tabs { position: static; padding: 0 0 10px; }
      .cover, .section {
        box-shadow: none;
        break-inside: avoid;
        page-break-inside: avoid;
        border-radius: var(--radius-panel);
      }
      .tab-label { box-shadow: none; }
      h1 { font-size: 24px; }
      h2, summary { font-size: 17px; }
      table { font-size: 10px; }
      th, td { padding: 5px 6px; }
      .table-wrap,
      .table-scroll { overflow: visible; }
    }
  </style>
</head>
<body>
<main class="report">
  <header class="cover">
    <div class="eyebrow">Отчёт по спортивным бальным танцам</div>
    <h1>{{ dancer.name }}</h1>
    <p class="cover-subtitle">
      {% if dancer.club %}Клуб {{ dancer.club }} · {% endif %}{% if dancer.city %}{{ dancer.city }} · {% endif %}IDD {{ dancer.idd }}
    </p>
    <div class="header-filter-panel" aria-label="Фильтры отчёта">
      <div class="header-city-filter">
        <div class="filter-chips" role="group" aria-label="Фильтр городов">
          <button class="city-chip report-filter-city-all" type="button" aria-pressed="true" aria-label="Показать все города">Все города</button>
          {% for city in filter_options.cities %}
            <button class="city-chip report-filter-city" type="button" data-city="{{ city }}" aria-pressed="true" aria-label="Фильтр города: {{ city }}">
              {{ city }}
            </button>
          {% endfor %}
        </div>
      </div>
      <div class="header-date-filter" role="group" aria-label="Фильтр периода">
        <input id="report-filter-date-from" type="date" value="{{ filter_options.date_from }}" aria-label="Дата начала периода">
        <span class="date-separator" aria-hidden="true">—</span>
        <input id="report-filter-date-to" type="date" value="{{ filter_options.date_to }}" aria-label="Дата окончания периода">
      </div>
    </div>
  </header>

  <input class="tab-input" type="radio" name="report-mode" id="tab-trainer" checked>
  <input class="tab-input" type="radio" name="report-mode" id="tab-parent">

  <nav class="tabs" aria-label="Режим просмотра отчёта">
    <label class="tab-label" for="tab-trainer">
      <span class="tab-title">Тренеру</span>
      <span class="tab-help">Разбор программ, динамики, танцев и турниров</span>
    </label>
    <label class="tab-label" for="tab-parent">
      <span class="tab-title">Родителю</span>
      <span class="tab-help">Кратко и понятно о прогрессе</span>
    </label>
  </nav>

  <section class="mode-panel parent-panel">
    <section class="section">
      <h2>Общая оценка сезона</h2>
      <p class="section-kicker">Краткая сводка по турнирам и динамике выступлений.</p>
      <div class="kpi-grid">
        <div class="card"><div class="label">Турниры</div><div class="kpi-value">{{ summary.tournaments }}</div><div class="muted">{{ summary.tournaments|pluralize("турнир", "турнира", "турниров") }} в отчёте</div></div>
        <div class="card"><div class="label">Выступления</div><div class="kpi-value">{{ summary.protocols }}</div><div class="muted">{{ summary.protocols|pluralize("выступление", "выступления", "выступлений") }}</div></div>
        <div class="card"><div class="label">Период наблюдения</div><div class="kpi-value" style="font-size:20px">{{ summary.date_from }} — {{ summary.date_to }}</div></div>
      </div>
      <div class="note-box">
        <div class="label">Общий вывод</div>
        <div class="big-status">{{ role_views.parent.season_status }}</div>
        <p>{{ role_views.parent.season_comment }}</p>
      </div>
    </section>

    <section class="section">
      <h2>Выводы по программам</h2>
      <p class="section-kicker">Стандарт и латина показаны отдельно, чтобы не смешивать разные программы.</p>
      {% for key, program in role_views.parent.programs.items() %}
      <div class="program-story">
        <h3 class="program-heading">{{ program.title|capitalize }}</h3>
        {% for group in program.category_groups %}
          <input class="category-input" type="radio" name="parent-cat-{{ key }}" id="parent-cat-{{ key }}-{{ group.key }}" {{ "checked" if loop.first else "" }}>
        {% endfor %}
        <div class="category-chip-groups">
          <div class="category-chip-group">
            <div class="category-group-title">Категории для родителя</div>
            <div class="category-tabs category-tabs-primary">
              {% for group in program.category_groups %}
                <label class="category-tab" for="parent-cat-{{ key }}-{{ group.key }}">{{ group.label }}</label>
              {% endfor %}
            </div>
          </div>
        </div>

        <div class="parent-category-panels">
          {% for group in program.category_groups %}
          <div class="parent-category-panel parent-panel-{{ key }}-{{ group.key }}">
            {% if group.included_categories|length > 1 %}
              <p class="section-kicker">В анализ включены старты: {{ group.included_categories|join(", ") }}</p>
            {% endif %}
            <div class="story-grid">
              <div class="story-card">
                <h4>Что получается лучше всего</h4>
                <p>{{ group.best_text }}</p>
              </div>
              <div class="story-card">
                <h4>Что требует внимания</h4>
                <p>{{ group.attention_text }}</p>
              </div>
            </div>
            <div class="story-card">
              <h4>Динамика</h4>
              <p>{{ group.trend_text }}</p>
              {% if group.attention_overlap_note %}
                <p class="muted">{{ group.attention_overlap_note }}</p>
              {% endif %}
              {% if group.limited %}
                <p class="muted">Для некоторых танцев пока недостаточно данных для устойчивых выводов.</p>
              {% endif %}
            </div>
            <div class="parent-conclusion">
              <h2>Общий вывод</h2>
              {% for line in group.overview %}
                <p>{{ line }}</p>
              {% endfor %}
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </section>

    <section class="section">
      <h2>Последние турниры</h2>
      <div class="plain-list">
        {% for item in role_views.parent.latest_tournaments %}
          <li class="filterable-tournament" data-city="{{ item.city or '' }}" data-date="{{ item.event_date or '' }}">
            <span>
              <strong>{{ item.event_date }}</strong> · {{ item.tournament_title }}
              {% if item.dance_codes %}
                <span class="muted">· {{ item.dance_codes|join(", ") }}</span>
              {% endif %}
            </span>
            <span class="muted">{{ item.protocols|pluralize("выступление", "выступления", "выступлений") }}</span>
          </li>
        {% endfor %}
      </div>
    </section>

  </section>

  <section class="mode-panel trainer-panel">
    {% for key, program in programs.items() %}
    <section class="section">
      <h2>{{ program.title|capitalize }}</h2>
      <p class="section-kicker">Категории переключаются отдельно для каждой программы. Меньшее место означает лучший результат.</p>

      {% for slice in program.category_slices %}
        <input class="category-input" type="radio" name="cat-{{ key }}" id="cat-{{ key }}-{{ slice.key }}" {{ "checked" if loop.first else "" }}>
      {% endfor %}
      <div class="category-chip-groups">
        {% if program.category_primary_slices %}
        <div class="category-chip-group">
          <div class="category-group-title">Основные категории</div>
          <div class="category-tabs category-tabs-primary">
            {% for slice in program.category_primary_slices %}
              <label class="category-tab" for="cat-{{ key }}-{{ slice.key }}">{{ slice.label }}</label>
            {% endfor %}
          </div>
        </div>
        {% endif %}
        {% if program.category_limited_slices %}
        <div class="category-chip-group category-chip-group-limited">
          <div class="category-group-title">Мало данных</div>
          <div class="category-tabs category-tabs-limited">
            {% for slice in program.category_limited_slices %}
              <label class="category-tab limited" for="cat-{{ key }}-{{ slice.key }}">
                {{ slice.label }}<span class="chip-badge">мало данных</span>
              </label>
            {% endfor %}
          </div>
        </div>
        {% endif %}
      </div>

      <div class="category-panels">
      {% for slice in program.category_slices %}
        <div class="category-panel panel-{{ key }}-{{ slice.key }}">
          {% if slice.analysis_note %}
            <p class="section-kicker">{{ slice.analysis_note }}</p>
          {% endif %}
          {% if slice.visibility_status == "limited" %}
            <div class="note-box limited-note">{{ icon("info", "neutral") }}Выборка ограничена: {{ slice.visibility.protocols_count|default(slice.protocol_count)|pluralize("протокол", "протокола", "протоколов") }}. Эти данные можно использовать как справку, но не как устойчивый вывод.</div>
          {% elif slice.protocol_count < 3 %}
            <div class="note-box limited-note">{{ icon("info", "neutral") }}Ограниченная выборка: {{ slice.protocol_count|pluralize("протокол", "протокола", "протоколов") }} в этом срезе.</div>
          {% endif %}

          {% if slice.visibility_status == "limited" %}
          <div class="three-column">
            <div class="insight-card neutral">
              <h3><span>Справка по участию</span>{{ icon("info") }}</h3>
              <p>{{ slice.visibility.marks_count|default(0)|pluralize("оценка", "оценки", "оценок") }} · {{ slice.visibility.tournaments_count|default(0)|pluralize("турнир", "турнира", "турниров") }}</p>
            </div>
            <div class="insight-card neutral">
              <h3>Танцы в срезе</h3>
              {% if slice.marks_derived_dance_metrics %}
                <p>{{ slice.marks_derived_dance_metrics|map(attribute="dance_code")|join(", ") }}</p>
              {% else %}
                <p class="muted">Данных по танцам мало.</p>
              {% endif %}
            </div>
            <div class="insight-card neutral">
              <h3>Как читать</h3>
              <p class="muted">Сравнения и динамика не выделяются, потому что выборка слишком мала для устойчивого вывода.</p>
            </div>
          </div>
          {% else %}
          <div class="three-column">
            {% if slice.display_mode == "all_equal" %}
            <div class="insight-card neutral">
              <h3>Сравнение танцев</h3>
              <p>{{ icon("equal", "neutral") }}Танцы показали одинаковый результат: {{ slice.tied_dances|map(attribute="dance")|map("dance_label")|join(", ") }} — место {{ slice.tied_metric_value|fmt }}.</p>
            </div>
            {% elif slice.display_mode == "single_dance" and slice.evaluated_dance %}
            <div class="insight-card">
              <h3>Оценённый танец</h3>
              <p>{{ slice.evaluated_dance.dance|dance_label }} — место {{ slice.evaluated_dance.final_avg_place|fmt }}.</p>
            </div>
            {% else %}
            <div class="insight-card positive">
              <h3><span>{{ "Лучшие танцы" if slice.best|length > 1 else "Лучший танец" }}</span>{{ icon("star") }}</h3>
              {% if slice.best %}
              <ul class="plain-list">
                {% for item in slice.best %}
                  <li><strong>{{ item.dance|dance_label }}</strong><span class="muted">{{ item.final_avg_place|fmt }}</span></li>
                {% endfor %}
              </ul>
              {% else %}<p class="muted">Ограниченная выборка.</p>{% endif %}
            </div>
            <div class="insight-card attention">
              <h3><span>Требуют внимания</span>{{ icon("alert") }}</h3>
              {% if slice.attention %}
              <ul class="plain-list">
                {% for item in slice.attention %}
                  <li><strong>{{ item.dance|dance_label }}</strong><span class="muted">{{ item.final_avg_place|fmt }}</span></li>
                {% endfor %}
              </ul>
              {% else %}<p class="muted">Ограниченная выборка.</p>{% endif %}
            </div>
            {% endif %}
            <div class="insight-card">
              <h3>Наиболее стабильные</h3>
              {% if slice.stable %}
              <ul class="plain-list">
                {% for item in slice.stable %}
                  <li>
                    <strong>{{ item.dance|dance_label }}</strong>
                    <span class="stability-meter">
                      <span class="progress-label">{{ item.stability_label }}</span>
                      <span class="progress-track"><span class="progress-fill" style="{{ item.stability_style }}"></span></span>
                    </span>
                  </li>
                {% endfor %}
              </ul>
              {% else %}<p class="muted">Ограниченная выборка.</p>{% endif %}
            </div>
          </div>

          <div class="three-column">
            <div class="insight-card positive">
              <h3><span>Улучшается</span>{{ icon("up") }}</h3>
              {% if slice.improving %}
                <ul class="plain-list">{% for item in slice.improving %}<li><strong>{{ item.dance|dance_label }}</strong><span class="muted">{{ item.first_avg_place|fmt }} → {{ item.last_avg_place|fmt }}</span></li>{% endfor %}</ul>
              {% else %}<p class="muted">{{ "Для уверенного вывода пока мало наблюдений." if not slice.enough_data else "Явного улучшения по тренду сейчас не видно." }}</p>{% endif %}
            </div>
            <div class="insight-card attention">
              <h3><span>Требует внимания по динамике</span>{{ icon("down") }}</h3>
              {% if slice.declining %}
                <ul class="plain-list">{% for item in slice.declining %}<li><strong>{{ item.dance|dance_label }}</strong><span class="muted">{{ item.first_avg_place|fmt }} → {{ item.last_avg_place|fmt }}</span></li>{% endfor %}</ul>
              {% else %}<p class="muted">{{ "Для уверенного вывода пока мало наблюдений." if not slice.enough_data else "Тревожной динамики по тренду сейчас не видно." }}</p>{% endif %}
            </div>
            <div class="insight-card">
              <h3>Стабильно</h3>
              {% if slice.stable_trends %}
                <ul class="plain-list">{% for item in slice.stable_trends %}<li><strong>{{ item.dance|dance_label }}</strong><span class="muted">{{ item.first_avg_place|fmt }} → {{ item.last_avg_place|fmt }}</span></li>{% endfor %}</ul>
              {% else %}<p class="muted">{{ "Для уверенного вывода пока мало наблюдений." if not slice.enough_data else "Отдельной группы стабильной динамики сейчас не выделяется." }}</p>{% endif %}
            </div>
          </div>
          {% endif %}

          <h3 class="dance-table-heading">Танцы</h3>
          <p class="section-kicker">Стабильность показывает, насколько сильно меняется итоговое место танца от турнира к турниру. Чем меньше колебания, тем выше стабильность.</p>
          <div class="table-wrap table-scroll">
            <table>
              <thead><tr><th class="col-dance">Танец</th><th class="number col-avg">Среднее место</th><th class="number col-best">Лучшее</th><th class="col-stability">Стабильность</th></tr></thead>
              <tbody>
              {% for item in slice.metrics %}
                <tr>
                  <td class="col-dance"><strong>{{ item.dance|dance_label }}</strong></td>
                  <td class="number col-avg">{{ item.final_avg_place|fmt }}</td>
                  <td class="number col-best">{{ item.best_place|fmt }}</td>
                  <td class="col-stability">
                    <div class="progress-label">{{ item.stability_label }}</div>
                    <div class="progress-track"><div class="progress-fill" style="{{ item.stability_style }}"></div></div>
                  </td>
                </tr>
              {% endfor %}
              {% if not slice.metrics %}
                <tr><td colspan="4">{{ "Нет устойчивых метрик по танцам в этом срезе." if slice.visibility_status == "limited" else "Ограниченная выборка." }}</td></tr>
              {% endif %}
              </tbody>
            </table>
          </div>

        </div>
      {% endfor %}
      </div>
      <div class="note-box">Расчёт стабильности основан на разбросе итоговых мест по турнирам. Полная шкала означает очень устойчивый результат, короткая шкала — сильные колебания.</div>
    </section>
    {% endfor %}

    <section class="section">
      <details>
        <summary>Дополнительная аналитика судей</summary>
        <p class="section-kicker">В рейтинг включены только судьи, по которым доступно не менее 10 оценок.</p>
        <div class="two-column">
          <div>
            <h3>Более строгие судьи</h3>
            <div class="table-wrap table-scroll">
              <table>
                <thead><tr><th>Судья</th><th>Интерпретация</th><th class="number">Оценок</th></tr></thead>
                <tbody>
                {% if judges.strictest %}
                {% for item in judges.strictest %}
                  <tr><td>{{ item.judge }}</td><td><div class="interpretation">{{ item.judge_label }}</div><div class="tiny">отклонение от панели: {{ item.avg_deviation|fmt }}</div></td><td class="number">{{ item.n_marks|pluralize("оценка", "оценки", "оценок") }}</td></tr>
                {% endfor %}
                {% else %}
                  <tr><td colspan="3">Недостаточно данных для формирования рейтинга судей.</td></tr>
                {% endif %}
                </tbody>
              </table>
            </div>
          </div>
          <div>
            <h3>Более мягкие судьи</h3>
            <div class="table-wrap table-scroll">
              <table>
                <thead><tr><th>Судья</th><th>Интерпретация</th><th class="number">Оценок</th></tr></thead>
                <tbody>
                {% if judges.softest %}
                {% for item in judges.softest %}
                  <tr><td>{{ item.judge }}</td><td><div class="interpretation">{{ item.judge_label }}</div><div class="tiny">отклонение от панели: {{ item.avg_deviation|fmt }}</div></td><td class="number">{{ item.n_marks|pluralize("оценка", "оценки", "оценок") }}</td></tr>
                {% endfor %}
                {% else %}
                  <tr><td colspan="3">Недостаточно данных для формирования рейтинга судей.</td></tr>
                {% endif %}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </details>
    </section>

    <section class="section">
      <h2>Турниры</h2>
      <p class="section-kicker">Лучшие и наиболее сложные выступления отмечены прямо в списке.</p>
      <div class="tournament-list">
        {% for item in trainer_tournament_summaries %}
        <details class="filterable-tournament" data-city="{{ item.city or '' }}" data-date="{{ item.event_date or '' }}">
          <summary>
            <div class="tournament-summary-row">
              <div class="tournament-summary">
                <div>
                  <div class="label">Дата</div>
                  <div class="summary-title">{{ item.event_date }}</div>
                  {% if item.city %}<div class="summary-meta">{{ item.city }}</div>{% endif %}
                </div>
                <div>
                  <div class="label">Турнир</div>
                  <div class="tournament-title-line">
                    <div class="summary-title">{{ item.tournament_title }}</div>
                    {% if item.rank_direction == "best" %}
                      <span class="tournament-badge best">{{ icon("star") }}лучший результат</span>
                    {% elif item.rank_direction == "hardest" %}
                      <span class="tournament-badge hardest">{{ icon("alert", "attention") }}сложное выступление</span>
                    {% endif %}
                  </div>
                </div>
                <div>
                  <div class="label">Категория / программа</div>
                  <div class="summary-meta">{{ item.categories|join("; ") }}</div>
                  <div class="summary-meta">{{ item.programs|map("program_label")|join(", ") }}</div>
                </div>
              </div>
              <span class="accordion-icon" aria-hidden="true">{{ icon("chevron") }}</span>
            </div>
          </summary>
          <div class="tournament-detail-grid">
            {% for program in item.program_summaries %}
              <div class="insight-card tournament-program-summary">
                <h3>{{ program.program_label }}</h3>
                <p class="muted">
                  Общий итог:
                  {% if program.overall.avg_place is not none %}
                    среднее место {{ program.overall.avg_place|fmt }} · {{ program.overall.dance_codes|join(", ") }}
                  {% else %}
                    {{ program.overall.dance_codes|join(", ") }} · {{ program.metric_label or "по оценкам судей" }}
                  {% endif %}
                </p>
                {% if program.display_mode == "best_worst" %}
                  {% if program.metric_type == "cross_count" %}
                    <p><strong>{{ icon("star", "positive") }}{% if program.best_dances|length > 1 %}Лучшие танцы{% else %}Лучший танец{% endif %}:</strong> {{ program.best_dances|map(attribute="dance_code")|join(", ") }} <span class="muted">— {{ program.best_dance.interpretation }} · {{ program.best_dance.cross_count }} крестов</span></p>
                    <p><strong>{{ icon("alert", "attention") }}{% if program.worst_dances|length > 1 %}Требуют внимания{% else %}Требует внимания{% endif %}:</strong> {{ program.worst_dances|map(attribute="dance_code")|join(", ") }} <span class="muted">— {{ program.worst_dance.interpretation }} · {{ program.worst_dance.cross_count }} крестов</span></p>
                  {% else %}
                    <p><strong>{{ icon("star", "positive") }}{% if program.best_dances|length > 1 %}Лучшие танцы{% else %}Лучший танец{% endif %}:</strong> {{ program.best_dances|map(attribute="dance_code")|join(", ") }} <span class="muted">место {{ program.best_dance.final_place|fmt }}</span></p>
                    <p><strong>{{ icon("alert", "attention") }}{% if program.worst_dances|length > 1 %}Требуют внимания{% else %}Требует внимания{% endif %}:</strong> {{ program.worst_dances|map(attribute="dance_code")|join(", ") }} <span class="muted">место {{ program.worst_dance.final_place|fmt }}</span></p>
                  {% endif %}
                {% elif program.display_mode == "single_dance" and program.evaluated_dance %}
                  {% if program.metric_type == "cross_count" %}
                    <p><strong>Оценённый танец:</strong> {{ program.evaluated_dance.dance_code }} <span class="muted">— {{ program.evaluated_dance.cross_count }} крестов</span></p>
                  {% else %}
                    <p><strong>Оценённый танец:</strong> {{ program.evaluated_dance.dance_code }} <span class="muted">— место {{ program.evaluated_dance.final_place|fmt }}</span></p>
                  {% endif %}
                {% elif program.display_mode == "tied" %}
                  {% if program.metric_type == "cross_count" %}
                    <p><strong>{{ icon("equal", "neutral") }}Танцы оценены примерно одинаково:</strong> {{ program.tied_dances|join(", ") }} <span class="muted">— {{ program.tied_metric_value }} крестов</span></p>
                  {% else %}
                    <p><strong>{{ icon("equal", "neutral") }}Танцы оценены примерно одинаково:</strong> {{ program.tied_dances|join(", ") }} <span class="muted">— среднее место {{ program.tied_metric_value|fmt }}</span></p>
                  {% endif %}
                {% else %}
                  <p class="muted">Недостаточно данных для лучшего и худшего танца.</p>
                {% endif %}
              </div>
            {% endfor %}
          </div>
          <div class="table-wrap table-scroll">
            <table>
              <thead><tr><th class="col-dance">Танец</th><th class="col-program">Программа</th><th class="number col-place">Итоговое место</th><th class="number col-protocols">Протоколов</th></tr></thead>
              <tbody>
              {% for result in item.dance_results %}
                <tr>
                  <td class="col-dance"><strong>{{ result.dance_code or (result.dance|dance_code) }}</strong></td>
                  <td class="col-program">{{ result.program|program_label }}</td>
                  <td class="number col-place">{{ result.final_place|fmt }}</td>
                  <td class="number col-protocols">{{ result.n_results|pluralize("протокол", "протокола", "протоколов") }}</td>
                </tr>
              {% endfor %}
              </tbody>
            </table>
          </div>
        </details>
        {% endfor %}
      </div>
    </section>

  </section>
</main>
  <script>
  (function () {
    var cityAllButton = document.querySelector(".report-filter-city-all");
    var cityButtons = Array.prototype.slice.call(document.querySelectorAll(".report-filter-city"));
    var dateFrom = document.getElementById("report-filter-date-from");
    var dateTo = document.getElementById("report-filter-date-to");
    var items = Array.prototype.slice.call(document.querySelectorAll(".filterable-tournament"));

    function isPressed(button) {
      return button && button.getAttribute("aria-pressed") === "true";
    }

    function setPressed(button, value) {
      if (button) button.setAttribute("aria-pressed", value ? "true" : "false");
    }

    function syncAllButton() {
      var allSelected = cityButtons.length === 0 || cityButtons.every(isPressed);
      setPressed(cityAllButton, allSelected);
    }

    function selectAllCities() {
      cityButtons.forEach(function (button) { setPressed(button, true); });
      setPressed(cityAllButton, true);
    }

    function selectedCities() {
      var selected = cityButtons
        .filter(isPressed)
        .map(function (button) { return button.getAttribute("data-city") || ""; })
        .filter(Boolean);
      if (!selected.length) {
        selectAllCities();
        return cityButtons.map(function (button) { return button.getAttribute("data-city") || ""; }).filter(Boolean);
      }
      return selected;
    }

    function inDateRange(value, from, to) {
      if (!value) return true;
      if (from && value < from) return false;
      if (to && value > to) return false;
      return true;
    }

    function applyFilters() {
      var cities = selectedCities();
      var from = dateFrom ? dateFrom.value : "";
      var to = dateTo ? dateTo.value : "";
      items.forEach(function (item) {
        var city = item.getAttribute("data-city") || "";
        var date = item.getAttribute("data-date") || "";
        var cityOk = !city || cities.indexOf(city) !== -1;
        var dateOk = inDateRange(date, from, to);
        item.hidden = !(cityOk && dateOk);
      });
    }

    if (cityAllButton) {
      cityAllButton.addEventListener("click", function () {
        selectAllCities();
        applyFilters();
      });
    }
    cityButtons.forEach(function (button) {
      button.addEventListener("click", function () {
        setPressed(button, !isPressed(button));
        if (!cityButtons.some(isPressed)) {
          selectAllCities();
        } else {
          syncAllButton();
        }
        applyFilters();
      });
    });
    if (dateFrom) dateFrom.addEventListener("change", applyFilters);
    if (dateTo) dateTo.addEventListener("change", applyFilters);
    selectAllCities();
    applyFilters();
  }());
</script>
</body>
</html>
