    .interpretation {
      color: var(--ink-soft);
      font-weight: 650;
      margin-top: 2px;
    }

    .judge-table-stack {
      display: grid;
      gap: 22px;
      margin-top: 12px;
    }

    .judge-table-block h3 {
      margin-bottom: 10px;
    }

    .judge-mobile-note {
      display: none;
    }

    .judge-insight-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
      margin-top: 16px;
    }

    .judge-insight-card {
      background: var(--paper-soft);
      border: 1px solid rgba(233, 229, 244, .82);
      border-radius: var(--radius-card);
      padding: 15px;
      break-inside: avoid;
    }

    .judge-insight-card h3 {
      color: var(--ink);
      font-size: 18px;
      font-weight: 600;
      line-height: 1.3;
      margin-bottom: 10px;
    }

    .judge-insight-card h3 + .judge-insight-description {
      margin-top: 0;
      margin-bottom: 12px;
    }

    .judge-consensus-list {
      display: grid;
      gap: 12px;
      margin-top: 12px;
    }

    .judge-consensus-item {
      display: grid;
      gap: 6px;
      padding-top: 12px;
      border-top: 1px solid rgba(233, 229, 244, .72);
    }

    .judge-consensus-item:first-child {
      padding-top: 0;
      border-top: 0;
    }

    .judge-consensus-name {
      color: var(--ink);
      font-size: 14.5px;
      font-weight: 560;
      line-height: 1.4;
    }

    .judge-consensus-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: fit-content;
      min-height: var(--chip-small-min-height);
      border-radius: var(--chip-radius);
      background: var(--accent-neutral-bg);
      color: var(--accent-neutral);
      font-size: var(--chip-small-font-size);
      font-weight: var(--chip-small-font-weight);
      line-height: var(--chip-small-line-height);
      padding: var(--chip-small-padding-y) var(--chip-small-padding-x);
    }

    .judge-consensus-badge.positive {
      background: var(--accent-positive-bg);
      color: var(--accent-positive);
    }

    .judge-consensus-badge.attention {
      background: var(--accent-attention-bg);
      color: var(--accent-attention);
    }

    .judge-insight-item + .judge-insight-item {
      margin-top: 12px;
      padding-top: 12px;
      border-top: 1px solid rgba(233, 229, 244, .72);
    }

    .judge-insight-title {
      color: var(--muted);
      font-size: 12px;
      font-weight: 500;
      margin-bottom: 4px;
    }

    .judge-insight-headline {
      color: var(--ink);
      font-size: 14.5px;
      font-weight: 560;
      line-height: 1.4;
    }

    .judge-list-name {
      color: var(--ink);
      font-size: 12.5px;
      font-weight: 520;
      line-height: 1.4;
    }

    .judge-insight-meta {
      color: var(--muted);
      font-size: 12.5px;
      font-weight: 400;
      line-height: 1.45;
      margin-top: 3px;
    }

    .judge-insight-description {
      color: var(--muted);
      font-size: 12px;
      font-weight: 400;
      line-height: 1.5;
      margin-top: 12px;
    }

    .note-box {
      border-radius: var(--radius-panel);
      padding: 12px 14px;
      margin-top: 10px;
    }

    .note-box {
      background: var(--note-soft);
      border: 0;
      color: var(--ink-soft);
    }

    .note-box.limited-note {
      background: var(--accent-neutral-bg);
    }

    .program-story {
      display: grid;
      gap: 16px;
    }

    .program-story + .program-story {
      margin-top: 22px;
      padding-top: 22px;
      border-top: 1px solid var(--line);
    }

    .story-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      margin-top: 14px;
    }

    .story-card {
      background: transparent;
      border-radius: 0;
      padding: 0;
    }

    .story-card h3,
    .story-card h4 {
      color: var(--ink-soft);
      font-size: 14px;
      font-weight: 560;
      margin-bottom: 8px;
